@model List<OltDisplayVM>
@{ ViewData["Title"] = "OLTs"; }
<div class="page-header d-flex justify-content-between align-items-center">
  <h1 class="page-title"><i class="bi bi-hdd-network me-2"></i>OLTs</h1>
  @if (!User.IsInRole("Visiteur")) {
    <a asp-action="Create" class="btn btn-primary btn-sm"><i class="bi bi-plus-lg me-1"></i>Nouvel OLT</a>
  }
</div>
@if (!Model.Any()) {
  <div class="alert alert-info">Aucun OLT accessible.</div>
} else {
  <div class="card shadow-sm">
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead class="table-light"><tr>
          <th>Nom</th><th>Zone</th><th>IP</th><th>Ports</th><th class="text-end">Actions</th>
        </tr></thead>
        <tbody>
          @foreach (var o in Model) {
          <tr>
            <td class="fw-semibold">@o.Nom</td>
            <td>@o.ZoneNom</td>
            <td><code>@(o.IpAddress ?? "—")</code></td>
            <td>@o.NbrePorts</td>
            <td class="text-end">
              @if (!User.IsInRole("Visiteur")) {
                <a asp-action="Edit" asp-route-id="@o.Id" class="btn btn-sm btn-outline-secondary me-1"><i class="bi bi-pencil"></i></a>
                <form asp-action="Delete" asp-route-id="@o.Id" method="post" class="d-inline">
                  @Html.AntiForgeryToken()
                  <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                </form>
              }
            </td>
          </tr>
          }
        </tbody>
      </table>
    </div>
  </div>
}
