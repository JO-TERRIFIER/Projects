@model SmartGPON.Web.ViewModels.OltCreateVM
@{ ViewData["Title"] = "Nouvel OLT"; }

<link rel="stylesheet" href="~/css/gpon-modal.css" />

<div class="gpon-overlay">
  <div class="gpon-modal">
    <div class="gpon-modal-header">
      <h5><i class="bi bi-hdd-network me-2"></i>Nouvel OLT</h5>
      <a href="@Url.Action("Index")" class="btn-close-modal">✕</a>
    </div>
    <div class="gpon-modal-body">
      <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()
        <div class="row g-3">
          <div class="col-md-8">
            <label asp-for="Nom" class="form-label text-muted small mb-1">Nom <span class="text-danger">*</span></label>
            <input asp-for="Nom" class="form-control" placeholder="Ex: OLT-Z1-01">
            <span asp-validation-for="Nom" class="text-danger small"></span>
          </div>
          <div class="col-md-4">
            <label asp-for="NbrePorts" class="form-label text-muted small mb-1">Nombre de ports</label>
            <input asp-for="NbrePorts" class="form-control" type="number" min="1" placeholder="16">
            <span asp-validation-for="NbrePorts" class="text-danger small"></span>
          </div>
          <div class="col-md-6">
            <label asp-for="IpAddress" class="form-label text-muted small mb-1">Adresse IP</label>
            <input asp-for="IpAddress" class="form-control" placeholder="192.168.1.1">
            <span asp-validation-for="IpAddress" class="text-danger small"></span>
          </div>
          <div class="col-md-6">
            <label asp-for="ZoneId" class="form-label text-muted small mb-1">Zone <span class="text-danger">*</span></label>
            <select asp-for="ZoneId" class="form-select">
              <option value="">— Sélectionner une zone —</option>
              @if (ViewBag.Zones != null)
              {
                foreach (var z in (IEnumerable<SmartGPON.Core.Entities.Zone>)ViewBag.Zones)
                {
                  <option value="@z.Id">@z.Nom (@(z.Projet?.Nom ?? ""))</option>
                }
              }
            </select>
            <span asp-validation-for="ZoneId" class="text-danger small"></span>
          </div>
        </div>
        <div class="gpon-modal-footer">
          <a href="@Url.Action("Index")" class="btn-cancel">Annuler</a>
          <button type="submit" class="btn sg-btn sg-btn-primary">
            <i class="bi bi-check2 me-1"></i>Enregistrer
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

@section Scripts {
  @if (!ViewData.ModelState.IsValid) {
    <script>document.querySelector('.gpon-modal')?.scrollIntoView({behavior:'smooth'});</script>
  }
}
