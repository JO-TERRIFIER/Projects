@model OltCreateVM
@{ ViewData["Title"] = "Nouvel OLT"; }
<div class="page-header"><h1 class="page-title"><i class="bi bi-hdd-network me-2"></i>Nouvel OLT</h1></div>
<div class="card shadow-sm" style="max-width:600px">
  <div class="card-body">
    <form asp-action="Create" method="post">
      @Html.AntiForgeryToken()
      <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
      <div class="mb-3">
        <label asp-for="Nom" class="form-label fw-semibold">Nom</label>
        <input asp-for="Nom" class="form-control" placeholder="Ex: OLT-NORD-01" />
        <span asp-validation-for="Nom" class="text-danger small"></span>
      </div>
      <div class="mb-3">
        <label asp-for="ZoneId" class="form-label fw-semibold">Zone</label>
        <select asp-for="ZoneId" class="form-select" asp-items="ViewBag.ZonesSelectList">
          <option value="">— Choisir une zone —</option>
        </select>
        <span asp-validation-for="ZoneId" class="text-danger small"></span>
      </div>
      <div class="mb-3">
        <label asp-for="IpAddress" class="form-label fw-semibold">Adresse IP <small class="text-muted">(optionnel)</small></label>
        <input asp-for="IpAddress" class="form-control" placeholder="Ex: 192.168.1.10" />
      </div>
      <div class="mb-4">
        <label asp-for="NbrePorts" class="form-label fw-semibold">Nombre de ports</label>
        <input asp-for="NbrePorts" type="number" min="1" class="form-control" placeholder="Ex: 16" />
        <span asp-validation-for="NbrePorts" class="text-danger small"></span>
      </div>
      <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>Créer</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Annuler</a>
      </div>
    </form>
  </div>
</div>
