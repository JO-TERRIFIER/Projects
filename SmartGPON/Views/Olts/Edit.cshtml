@model OltUpdateVM
@{ ViewData["Title"] = "Modifier OLT"; }
<div class="page-header"><h1 class="page-title"><i class="bi bi-pencil-square me-2"></i>Modifier OLT</h1></div>
<div class="card shadow-sm" style="max-width:600px">
  <div class="card-body">
    <form asp-action="Edit" method="post">
      @Html.AntiForgeryToken()
      <input type="hidden" asp-for="Id" />
      <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
      <div class="mb-3">
        <label asp-for="Nom" class="form-label fw-semibold">Nom</label>
        <input asp-for="Nom" class="form-control" />
        <span asp-validation-for="Nom" class="text-danger small"></span>
      </div>
      <div class="mb-3">
        <label asp-for="ZoneId" class="form-label fw-semibold">Zone</label>
        <select asp-for="ZoneId" class="form-select" asp-items="ViewBag.ZonesSelectList">
          <option value="">— Choisir une zone —</option>
        </select>
      </div>
      <div class="mb-3">
        <label asp-for="IpAddress" class="form-label fw-semibold">Adresse IP</label>
        <input asp-for="IpAddress" class="form-control" />
      </div>
      <div class="mb-4">
        <label asp-for="NbrePorts" class="form-label fw-semibold">Nombre de ports</label>
        <input asp-for="NbrePorts" type="number" min="1" class="form-control" />
      </div>
      <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary"><i class="bi bi-floppy me-1"></i>Enregistrer</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Annuler</a>
      </div>
    </form>
  </div>
</div>
