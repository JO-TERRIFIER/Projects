@model IEnumerable<SmartGPON.Core.Entities.Fat>
@{ ViewData["Title"] = "FATs / Splitters"; }
<div class="page-header">
  <div><h1 class="page-title">Supervision FAT / Splitters</h1><div class="page-subtitle">Seuil max : 12 ONT/FAT</div></div>
  <a asp-action="Create" class="btn-primary-sg"><i class="bi bi-plus-lg"></i> Ajouter FAT</a>
</div>
<div class="page-body">
  @{
    var saturees = Model.Where(f => f.Capacite > 0 && f.Splitters.SelectMany(s=>s.Onts).Count() >= f.Capacite).ToList();
    if (saturees.Any()) {
      <div class="sg-alert sg-alert-red">
        <i class="bi bi-exclamation-octagon-fill text-r fs-5"></i>
        <div><div style="font-size:13px;font-weight:600;color:var(--accent-red)">FAT saturées (@saturees.Count)</div>
        <div style="font-size:12px;color:var(--text-muted);margin-top:2px">
          @string.Join(", ", saturees.Take(5).Select(f => f.Nom)) → capacité maximale atteinte
        </div></div>
      </div>
    }
  }
  <div class="sg-card p-0" style="overflow:hidden">
    <div style="overflow-x:auto">
      <table class="sg-table">
        <thead><tr>
          <th style="padding-left:20px">Code FAT</th><th>FDT parent</th><th>ONT actifs</th>
          <th>Capacité FAT</th><th>Statut</th><th style="padding-right:20px;text-align:right">Actions</th>
        </tr></thead>
        <tbody>
        @foreach(var f in Model){
          var onts = f.Splitters?.SelectMany(s=>s.Onts??new List<SmartGPON.Core.Entities.Ont>()).Count() ?? 0;
          var pct  = f.Capacite > 0 ? Math.Min(100, onts * 100 / f.Capacite) : 0;
          var barColor = pct >= 100 ? "var(--accent-red)" : pct >= 80 ? "var(--accent-amber)" : "var(--accent-green)";
          var pill     = pct >= 100 ? "pill-red" : pct >= 80 ? "pill-amber" : "pill-green";
          var label    = pct >= 100 ? "Saturé"   : pct >= 80 ? "Alerte"    : "Normal";
          var rowClass = pct >= 100 ? "row-overload" : pct >= 80 ? "row-warn" : "";
          <tr class="@rowClass">
            <td style="padding-left:20px">
              @if(pct>=100){<i class="bi bi-exclamation-circle-fill text-r me-2" style="font-size:13px"></i>}
              <span class="mono @(pct>=100?"text-r":"text-accent")">@f.Nom</span>
            </td>
            <td class="mono" style="font-size:11.5px;color:var(--text-muted)">@f.Fdt?.Nom</td>
            <td><span class="mono @(pct>=100?"text-r":pct>=80?"text-a":"text-g")" style="font-weight:600">@onts</span><span style="font-size:11px;color:var(--text-muted)"> / @f.Capacite</span></td>
            <td style="min-width:140px"><div class="d-flex align-items-center gap-2">
              <div class="cap-bar-lg" style="flex:1"><div class="cap-bar-lg-fill" style="width:@pct%;background:@barColor"></div></div>
              <span class="mono" style="font-size:12px;color:@barColor">@pct%</span>
            </div></td>
            <td><span class="pill @pill">@label</span></td>
            <td style="padding-right:20px;text-align:right"><div class="d-flex justify-content-end gap-1">
              <a asp-action="Edit" asp-route-id="@f.Id" class="icon-btn edit"><i class="bi bi-pencil"></i></a>
              <form asp-action="Delete" asp-route-id="@f.Id" method="post" class="d-inline" onsubmit="return confirm('Supprimer ?')">
                @Html.AntiForgeryToken()<button type="submit" class="icon-btn danger"><i class="bi bi-trash3"></i></button>
              </form>
            </div></td>
          </tr>
        }
        </tbody>
      </table>
    </div>
  </div>
</div>
