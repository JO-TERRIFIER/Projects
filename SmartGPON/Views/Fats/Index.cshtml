@model IEnumerable<SmartGPON.Core.Entities.Fat>
@{
  ViewData["Title"] = "FATs";
  var canWrite = User.IsInRole("Admin") || User.IsInRole("Technicien");
  var canDelete = User.IsInRole("Admin");
}
<div class="page-header">
  <div><h1 class="page-title">FATs</h1><div class="page-subtitle">Fibre Access Terminals — Capacité 8 ou 12</div></div>
  @if (canWrite)
  {
    <a asp-action="Create" class="btn-primary-sg"><i class="bi bi-plus-lg"></i> Ajouter FAT</a>
  }
</div>
<div class="page-body">
  <div class="sg-card p-0" style="overflow:hidden">
    <div style="overflow-x:auto">
      <table class="sg-table">
        <thead><tr>
          <th style="padding-left:20px">Code FAT</th><th>FDT parent</th>
          <th>Capacité</th><th>Statut</th><th style="padding-right:20px;text-align:right">Actions</th>
        </tr></thead>
        <tbody>
        @foreach(var f in Model){
          var pill = f.Statut==SmartGPON.Core.Enums.StatutEquipement.Actif?"pill-green":f.Statut==SmartGPON.Core.Enums.StatutEquipement.EnPanne?"pill-red":"pill-amber";
          <tr>
            <td style="padding-left:20px">
              <span class="mono text-accent">@f.Nom</span>
            </td>
            <td class="mono" style="font-size:11.5px;color:var(--text-muted)">@f.Fdt?.Nom</td>
            <td class="mono" style="color:var(--accent-cyan)">@f.Capacite</td>
            <td><span class="pill @pill">@f.Statut</span></td>
            <td style="padding-right:20px;text-align:right"><div class="d-flex justify-content-end gap-1">
              @if (canWrite)
              {
                <a asp-action="Edit" asp-route-id="@f.Id" class="icon-btn edit"><i class="bi bi-pencil"></i></a>
              }
              @if (canDelete)
              {
                <form asp-action="Delete" asp-route-id="@f.Id" method="post" class="d-inline" onsubmit="return confirm('Supprimer ?')">
                  @Html.AntiForgeryToken()<button type="submit" class="icon-btn danger"><i class="bi bi-trash3"></i></button>
                </form>
              }
            </div></td>
          </tr>
        }
        </tbody>
      </table>
    </div>
  </div>
</div>
