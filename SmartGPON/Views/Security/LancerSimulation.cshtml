@* Views/Security/LancerSimulation.cshtml *@
@model SmartGPON.Web.ViewModels.SimulationFormViewModel
@{ ViewData["Title"] = "Lancer une simulation"; }

<div class="page-header">
    <div>
        <h1 class="page-title"><i class="bi bi-activity me-2"></i>Nouvelle simulation d'attaque</h1>
        <div class="page-subtitle">Tester la rÃ©sistance du rÃ©seau GPON</div>
    </div>
    <a asp-action="Simulations" class="btn-ghost-sg"><i class="bi bi-arrow-left me-1"></i>Retour</a>
</div>

<div class="page-body">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="sg-card">
                <form asp-action="LancerSimulation" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="sg-label">OLT cible</label>
                        <select asp-for="OltId" class="sg-input">
                            <option value="">-- SÃ©lectionner un OLT --</option>
                            @foreach (var o in Model.Olts)
                            {
                                <option value="@o.Id">@o.Nom (@o.IpAddress)</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="sg-label">Type d'attaque *</label>
                        <select asp-for="TypeAttaque" class="sg-input" required>
                            <option value="">-- Choisir --</option>
                            <option value="MITM">MITM (Man-in-the-Middle)</option>
                            <option value="RogueOLT">Rogue OLT Injection</option>
                            <option value="DoS">DoS / Flooding</option>
                            <option value="TrafficSniff">Traffic Sniffing</option>
                            <option value="Replay">Replay Attack</option>
                            <option value="PortScan">Port Scanning</option>
                        </select>
                        <span asp-validation-for="TypeAttaque" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label class="sg-label">Niveau de risque</label>
                        <select asp-for="NiveauRisque" asp-items="Html.GetEnumSelectList<SmartGPON.Core.Enums.NiveauRisque>()" class="sg-input"></select>
                    </div>
                    <div class="mb-3"><label class="sg-label">Description action *</label><input name="actionDescription" class="sg-input" required placeholder="Pourquoi lancer cette simulation ?" /></div><div class="mb-4">
                        <label class="sg-label">ParamÃ¨tres (JSON optionnel)</label>
                        <textarea asp-for="Parametres" class="sg-input" rows="3" placeholder='{"intensity": 5, "duration": 30}'></textarea>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn-primary-sg"><i class="bi bi-play-fill me-1"></i>Lancer la simulation</button>
                        <a asp-action="Simulations" class="btn-ghost-sg">Annuler</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>


