@model AttackSimulationCreateVM
@{ ViewData["Title"] = "Lancer une simulation"; }

<div class="page-header">
  <h1 class="page-title"><i class="bi bi-play-circle me-2"></i>Lancer une simulation d'attaque</h1>
</div>

<div class="card shadow-sm" style="max-width:640px">
  <div class="card-body">
    <form asp-action="LancerSimulation" method="post">
      @Html.AntiForgeryToken()
      <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

      <div class="mb-3">
        <label class="form-label fw-semibold">OLT cible (optionnel)</label>
        <select asp-for="OltId" class="form-select">
          <option value="">— Aucun (test général) —</option>
        </select>
      </div>

      <div class="mb-3">
        <label asp-for="NiveauRisque" class="form-label fw-semibold">Niveau de risque</label>
        <select asp-for="NiveauRisque" class="form-select">
          <option value="@((int)NiveauRisque.Faible)">Faible</option>
          <option value="@((int)NiveauRisque.Moyen)" selected>Moyen</option>
          <option value="@((int)NiveauRisque.Eleve)">Élevé</option>
          <option value="@((int)NiveauRisque.Critique)">Critique</option>
        </select>
        <span asp-validation-for="NiveauRisque" class="text-danger small"></span>
      </div>

      <div class="mb-4">
        <label asp-for="Description" class="form-label fw-semibold">Description</label>
        <textarea asp-for="Description" class="form-control" rows="4" placeholder="Décrivez le type d'attaque simulée..."></textarea>
        <span asp-validation-for="Description" class="text-danger small"></span>
      </div>

      <div class="d-flex gap-2">
        <button type="submit" class="btn btn-danger">
          <i class="bi bi-play-fill me-1"></i>Lancer
        </button>
        <a asp-action="Index" class="btn btn-outline-secondary">Annuler</a>
      </div>
    </form>
  </div>
</div>
