@using SmartGPON.Core.Interfaces
@using SmartGPON.Core.Entities
@model SecurityDashboardData
@{ ViewData["Title"] = "Centre Sécurité"; }

<div class="page-header">
  <div class="d-flex align-items-center justify-content-between mb-4">
    <div>
      <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-1">
          <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Accueil</a></li>
          <li class="breadcrumb-item active">Centre Sécurité</li>
        </ol>
      </nav>
      <h1 class="h4 mb-0 fw-500"><i class="bi bi-shield me-2"></i>Centre Sécurité</h1>
    </div>
    @if (!User.IsInRole("Visiteur"))
    {
      <a asp-action="LancerSimulation" class="btn sg-btn sg-btn-primary">
        <i class="bi bi-bug me-1"></i>Lancer une simulation
      </a>
    }
  </div>
</div>

<div class="page-body">
  <div class="row g-3 mb-4">
    <div class="col-sm-6 col-lg-3">
      <div class="sg-card h-100">
        <div class="d-flex align-items-center justify-content-between mb-2">
          <span class="text-muted small">Simulations</span>
          <i class="bi bi-bug" style="font-size:18px;color:var(--color-telecom-blue)"></i>
        </div>
        <div class="h3 mb-0 fw-700">@Model.SimulationCount</div>
        <div class="text-muted" style="font-size:11px">total effectuées</div>
      </div>
    </div>
    <div class="col-sm-6 col-lg-3">
      <div class="sg-card h-100">
        <div class="d-flex align-items-center justify-content-between mb-2">
          <span class="text-muted small">Rogue OLTs</span>
          <i class="bi bi-exclamation-diamond" style="font-size:18px;color:var(--color-status-offline)"></i>
        </div>
        <div class="h3 mb-0 fw-700">@Model.RogueOltCount</div>
        <div class="text-muted" style="font-size:11px">détectés</div>
      </div>
    </div>
    <div class="col-sm-6 col-lg-3">
      <div class="sg-card h-100">
        <div class="d-flex align-items-center justify-content-between mb-2">
          <span class="text-muted small">Alertes</span>
          <i class="bi bi-bell-fill" style="font-size:18px;color:var(--color-status-warning)"></i>
        </div>
        <div class="h3 mb-0 fw-700">@Model.AlertCount</div>
        <div class="text-muted" style="font-size:11px">alertes réseau</div>
      </div>
    </div>
    <div class="col-sm-6 col-lg-3">
      <div class="sg-card h-100">
        <div class="d-flex align-items-center justify-content-between mb-2">
          <span class="text-muted small">Événements</span>
          <i class="bi bi-clock-history" style="font-size:18px;color:var(--color-status-online)"></i>
        </div>
        <div class="h3 mb-0 fw-700">@Model.SecurityEventCount</div>
        <div class="text-muted" style="font-size:11px">événements sécurité</div>
      </div>
    </div>
  </div>

  <div class="row g-3">
    <div class="col-lg-4">
      <div class="sg-card h-100">
        <h2 class="h6 mb-3 fw-600"><i class="bi bi-lightning me-2"></i>Accès rapides</h2>
        <div class="d-flex flex-column gap-2">
          @if (!User.IsInRole("Visiteur"))
          {
            <a asp-action="LancerSimulation" class="btn sg-btn sg-btn-outline w-100 justify-content-start">
              <i class="bi bi-bug me-2"></i>Lancer une simulation
            </a>
          }
          <a asp-action="Simulations" class="btn sg-btn sg-btn-outline w-100 justify-content-start">
            <i class="bi bi-list-ul me-2"></i>Voir les simulations
          </a>
          <a asp-action="RogueOlts" class="btn sg-btn sg-btn-outline w-100 justify-content-start">
            <i class="bi bi-exclamation-diamond me-2"></i>Rogue OLTs
          </a>
          <a asp-action="Alerts" class="btn sg-btn sg-btn-outline w-100 justify-content-start">
            <i class="bi bi-bell me-2"></i>Alertes réseau
          </a>
        </div>
      </div>
    </div>
    <div class="col-lg-8">
      <div class="sg-card h-100">
        <h2 class="h6 mb-3 fw-600"><i class="bi bi-bell me-2"></i>Alertes récentes</h2>
        @if (Model.RecentAlerts?.Any() == true)
        {
          <table class="sg-table">
            <thead>
              <tr>
                <th>Message</th>
                <th>Sévérité</th>
                <th>Date</th>
              </tr>
            </thead>
            <tbody>
              @foreach (var a in Model.RecentAlerts)
              {
                <tr>
                  <td>@a.Message</td>
                  <td>
                    @{
                      var sev = a.Severite.ToString();
                      var cls = sev is "Haute" or "Critical" or "Critique" ? "status-offline"
                              : sev is "Moyenne" or "Medium" or "Warning" ? "status-warning"
                              : "status-online";
                    }
                    <span class="badge-status @cls">@sev</span>
                  </td>
                  <td class="text-muted" style="font-size:12px">@a.OccurredAt.ToString("dd/MM/yyyy HH:mm")</td>
                </tr>
              }
            </tbody>
          </table>
        }
        else
        {
          <p class="text-muted small mb-0">Aucune alerte récente.</p>
        }
      </div>
    </div>
  </div>
</div>
