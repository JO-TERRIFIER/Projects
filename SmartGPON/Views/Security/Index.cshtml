@model SecurityDashboardData
@{ ViewData["Title"] = "Centre Sécurité"; }

<div class="page-header d-flex justify-content-between align-items-center">
  <h1 class="page-title"><i class="bi bi-shield-check me-2"></i>Centre Sécurité</h1>
</div>

<div class="row g-3 mb-4">
  <div class="col-6 col-lg-3">
    <div class="stat-card border-danger">
      <div class="stat-icon text-danger"><i class="bi bi-bell"></i></div>
      <div class="stat-value">@Model.AlertCount</div>
      <div class="stat-label">Alertes réseau</div>
    </div>
  </div>
  <div class="col-6 col-lg-3">
    <div class="stat-card border-warning">
      <div class="stat-icon text-warning"><i class="bi bi-exclamation-diamond"></i></div>
      <div class="stat-value">@Model.RogueOltCount</div>
      <div class="stat-label">Rogue OLTs</div>
    </div>
  </div>
  <div class="col-6 col-lg-3">
    <div class="stat-card border-info">
      <div class="stat-icon text-info"><i class="bi bi-activity"></i></div>
      <div class="stat-value">@Model.SimulationCount</div>
      <div class="stat-label">Simulations</div>
    </div>
  </div>
  <div class="col-6 col-lg-3">
    <div class="stat-card border-secondary">
      <div class="stat-icon text-secondary"><i class="bi bi-shield-exclamation"></i></div>
      <div class="stat-value">@Model.SecurityEventCount</div>
      <div class="stat-label">Événements sécu.</div>
    </div>
  </div>
</div>

<div class="row g-3">
  <div class="col-md-6">
    <div class="card shadow-sm">
      <div class="card-header d-flex justify-content-between align-items-center">
        <span class="fw-bold"><i class="bi bi-bell-fill text-danger me-2"></i>Alertes récentes</span>
        <a asp-action="Alerts" class="btn btn-sm btn-outline-danger">Voir tout</a>
      </div>
      <div class="card-body p-0">
        @if (!Model.RecentAlerts.Any())
        {
          <div class="p-3 text-muted" style="font-size:13px">Aucune alerte.</div>
        }
        else
        {
          <ul class="list-group list-group-flush">
            @foreach (var a in Model.RecentAlerts)
            {
              var badge = a.Severite == AlertSeverite.Critical ? "danger" : (a.Severite == AlertSeverite.Warning ? "warning" : "info");
              <li class="list-group-item d-flex justify-content-between align-items-center py-2">
                <div>
                  <span class="badge bg-@badge me-2">@a.Severite</span>
                  <span style="font-size:12px">@a.Message</span>
                  @if (a.Olt != null) { <span class="text-muted ms-1" style="font-size:11px">(@a.Olt.Nom)</span> }
                </div>
                <small class="text-muted">@a.OccurredAt.ToLocalTime().ToString("dd/MM HH:mm")</small>
              </li>
            }
          </ul>
        }
      </div>
    </div>
  </div>
  <div class="col-md-6">
    <div class="card shadow-sm">
      <div class="card-header d-flex justify-content-between align-items-center">
        <span class="fw-bold"><i class="bi bi-exclamation-diamond-fill text-warning me-2"></i>Rogue OLTs récents</span>
        <a asp-action="RogueOlts" class="btn btn-sm btn-outline-warning">Voir tout</a>
      </div>
      <div class="card-body p-0">
        @if (!Model.RecentRogueOlts.Any())
        {
          <div class="p-3 text-muted" style="font-size:13px">Aucun OLT malveillant.</div>
        }
        else
        {
          <ul class="list-group list-group-flush">
            @foreach (var m in Model.RecentRogueOlts)
            {
              <li class="list-group-item d-flex justify-content-between align-items-center py-2">
                <div>
                  @if (m.Olt != null) { <span class="badge bg-secondary me-1">@m.Olt.Nom</span> }
                  <span style="font-size:12px">@m.Reason</span>
                </div>
                <small class="text-muted">@m.DetectedAt.ToLocalTime().ToString("dd/MM HH:mm")</small>
              </li>
            }
          </ul>
        }
      </div>
    </div>
  </div>
</div>

<div class="mt-3">
  @if (!User.IsInRole("Visiteur"))
  {
    <a asp-action="LancerSimulation" class="btn btn-danger">
      <i class="bi bi-play-fill me-1"></i>Lancer une simulation
    </a>
  }
  <a asp-action="Simulations" class="btn btn-outline-secondary ms-2">
    <i class="bi bi-activity me-1"></i>Toutes les simulations
  </a>
</div>
