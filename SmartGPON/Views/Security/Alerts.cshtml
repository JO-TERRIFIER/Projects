@using SmartGPON.Core.Entities
@using SmartGPON.Core.Enums
@model List<SmartGPON.Core.Entities.NetworkAlert>
@{ ViewData["Title"] = "Alertes réseau"; }

<div class="page-header">
  <div class="d-flex align-items-center justify-content-between mb-4">
    <div>
      <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-1">
          <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Accueil</a></li>
          <li class="breadcrumb-item"><a asp-controller="Security" asp-action="Index">Centre Sécurité</a></li>
          <li class="breadcrumb-item active">Alertes</li>
        </ol>
      </nav>
      <h1 class="h4 mb-0 fw-500">
        <i class="bi bi-bell-fill me-2" style="color:var(--color-status-offline)"></i>Alertes réseau
      </h1>
    </div>
  </div>
</div>

<div class="page-body">
  <div class="sg-card">
    @if (Model.Any())
    {
      <table class="sg-table">
        <thead>
          <tr>
            <th>Message</th>
            <th>Sévérité</th>
            <th>OLT</th>
            <th>Date</th>
          </tr>
        </thead>
        <tbody>
          @foreach (var item in Model)
          {
            <tr>
              <td>@item.Message</td>
              <td>
                @{
                  var cls = item.Severite == AlertSeverite.Critical ? "status-offline"
                          : item.Severite == AlertSeverite.Warning ? "status-warning"
                          : "status-online";
                }
                <span class="badge-status @cls">@item.Severite</span>
              </td>
              <td class="text-muted small">@(item.Olt?.Nom ?? "—")</td>
              <td class="text-muted" style="font-size:12px">@item.OccurredAt.ToString("dd/MM/yyyy HH:mm")</td>
            </tr>
          }
        </tbody>
      </table>
    }
    else
    {
      <div class="text-center py-5 text-muted">
        <i class="bi bi-bell-slash" style="font-size:48px;opacity:0.3"></i>
        <p class="mt-3 mb-0">Aucune alerte réseau.</p>
      </div>
    }
  </div>
</div>
