@model IEnumerable<SmartGPON.Core.Entities.MaliciousOlt>
@{ ViewData["Title"] = "Rogue OLTs"; }
<div class="page-header"><div><h1 class="page-title"><i class="bi bi-exclamation-diamond me-2 text-a"></i>Rogue OLTs détectés</h1><div class="page-subtitle">Équipements suspects sur le réseau GPON</div></div>
  <a asp-controller="Security" asp-action="Index" class="btn-ghost-sg"><i class="bi bi-arrow-left"></i> Sécurité</a>
</div>
<div class="page-body">
  @if(!Model.Any()){
    <div class="sg-card text-center py-5"><i class="bi bi-shield-check fs-1 text-g mb-3 d-block"></i><div style="color:var(--text-muted)">Aucun rogue OLT détecté — réseau sécurisé</div></div>
  } else {
  <div class="sg-card p-0" style="overflow:hidden"><div style="overflow-x:auto"><table class="sg-table">
    <thead><tr><th style="padding-left:20px">IP Suspecte</th><th>MAC</th><th>OLT associé</th><th>Confiance</th><th>Raison</th><th>Détecté le</th><th>Statut</th><th style="padding-right:20px;text-align:right">Action</th></tr></thead>
    <tbody>
    @foreach(var m in Model){
      var conf = m.NiveauConfiance;
      var barColor = conf>=80?"var(--accent-red)":conf>=50?"var(--accent-amber)":"var(--accent-green)";
      var pillS = m.Statut==SmartGPON.Core.Enums.StatutMaliciousOlt.Actif?"pill-red":m.Statut==SmartGPON.Core.Enums.StatutMaliciousOlt.Resolu?"pill-green":"pill-amber";
      <tr style="@(m.Statut==SmartGPON.Core.Enums.StatutMaliciousOlt.Actif?"background:rgba(255,61,87,.04)":"")">
        <td style="padding-left:20px" class="mono" style="color:var(--accent-red)">@(m.IpSuspecte??"—")</td>
        <td class="mono" style="font-size:11.5px;color:var(--text-muted)">@(m.MacSuspecte??"—")</td>
        <td style="font-size:12px;color:var(--text-muted)">@(m.Olt?.Nom??"-")</td>
        <td style="min-width:140px"><div class="d-flex align-items-center gap-2">
          <div class="cap-bar-lg" style="flex:1"><div class="cap-bar-lg-fill" style="width:@conf%;background:@barColor"></div></div>
          <span class="mono" style="font-size:12px;color:@barColor">@conf%</span>
        </div></td>
        <td style="font-size:12px;max-width:200px;color:var(--text-muted);white-space:normal">@(m.RaisonDetection??"—")</td>
        <td class="mono" style="font-size:11.5px;color:var(--text-muted)">@m.DateDetection.ToString("dd/MM HH:mm")</td>
        <td><span class="pill @pillS">@m.Statut</span></td>
        <td style="padding-right:20px;text-align:right">
          @if(m.Statut==SmartGPON.Core.Enums.StatutMaliciousOlt.Actif){
            <form asp-action="ResolveRogue" asp-route-id="@m.Id" method="post" class="d-inline">
              @Html.AntiForgeryToken()<button type="submit" class="btn-ghost-sg" style="font-size:11px;padding:4px 10px"><i class="bi bi-check-circle me-1"></i>Résoudre</button>
            </form>
          }
        </td>
      </tr>
    }
    </tbody>
  </table></div></div>
  }
</div>
