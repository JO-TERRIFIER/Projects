@model List<MaliciousOltDisplayVM>
@{ ViewData["Title"] = "Rogue OLTs"; }
<div class="page-header"><h1 class="page-title"><i class="bi bi-exclamation-diamond me-2 text-warning"></i>Rogue OLTs détectés</h1></div>
@if (!Model.Any()) {
  <div class="alert alert-success"><i class="bi bi-shield-check me-2"></i>Aucun OLT malveillant détecté.</div>
} else {
  <div class="card shadow-sm">
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead class="table-light"><tr>
          <th>OLT</th><th>Raison</th><th>Détecté le</th>
        </tr></thead>
        <tbody>
          @foreach (var m in Model) {
          <tr>
            <td class="fw-semibold">@(m.OltNom ?? $"OLT #{m.OltId}")</td>
            <td style="font-size:13px;max-width:300px">@m.Reason</td>
            <td class="text-nowrap text-muted" style="font-size:12px">@m.DetectedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
          </tr>
          }
        </tbody>
      </table>
    </div>
  </div>
}
