@using SmartGPON.Web.ViewModels
@model List<MaliciousOltDisplayVM>
@{ ViewData["Title"] = "Rogue OLTs"; }

<div class="page-header">
  <div class="d-flex align-items-center justify-content-between mb-4">
    <div>
      <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-1">
          <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Accueil</a></li>
          <li class="breadcrumb-item"><a asp-controller="Security" asp-action="Index">Centre Sécurité</a></li>
          <li class="breadcrumb-item active">Rogue OLTs</li>
        </ol>
      </nav>
      <h1 class="h4 mb-0 fw-500">
        <i class="bi bi-exclamation-diamond me-2" style="color:var(--color-status-offline)"></i>Rogue OLTs détectés
      </h1>
    </div>
  </div>
</div>

<div class="page-body">
  <div class="sg-card">
    @if (Model.Any())
    {
      <table class="sg-table">
        <thead>
          <tr>
            <th>OLT</th>
            <th>Raison</th>
            <th>Détecté le</th>
          </tr>
        </thead>
        <tbody>
          @foreach (var item in Model)
          {
            <tr>
              <td class="fw-500">@(item.OltNom ?? $"OLT #{item.OltId}")</td>
              <td class="text-muted small">@item.Reason</td>
              <td class="text-muted" style="font-size:12px">@item.DetectedAt.ToString("dd/MM/yyyy HH:mm")</td>
            </tr>
          }
        </tbody>
      </table>
    }
    else
    {
      <div class="text-center py-5 text-muted">
        <i class="bi bi-shield-check" style="font-size:48px;color:var(--color-status-online);opacity:0.6"></i>
        <p class="mt-3 mb-0">Aucun OLT malveillant détecté.</p>
      </div>
    }
  </div>
</div>
