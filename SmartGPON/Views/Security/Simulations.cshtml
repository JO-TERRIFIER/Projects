@model List<AttackSimulationDisplayVM>
@{ ViewData["Title"] = "Simulations d'attaque"; }
<div class="page-header d-flex justify-content-between align-items-center">
  <h1 class="page-title"><i class="bi bi-activity me-2"></i>Simulations d'attaque</h1>
  @if (!User.IsInRole("Visiteur")) {
    <a asp-action="LancerSimulation" class="btn btn-danger btn-sm"><i class="bi bi-play-fill me-1"></i>Nouvelle simulation</a>
  }
</div>
@if (!Model.Any()) {
  <div class="alert alert-info">Aucune simulation enregistrée.</div>
} else {
  <div class="card shadow-sm">
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead class="table-light"><tr>
          <th>Risque</th><th>Description</th><th>OLT cible</th><th>Lancé par</th><th>Date</th>
        </tr></thead>
        <tbody>
          @foreach (var s in Model) {
          var badge = s.NiveauRisque == NiveauRisque.Critique ? "danger" :
                      s.NiveauRisque == NiveauRisque.Eleve ? "warning" :
                      s.NiveauRisque == NiveauRisque.Moyen ? "info" : "secondary";
          <tr>
            <td><span class="badge bg-@badge">@s.NiveauRisque</span></td>
            <td style="max-width:260px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;font-size:13px">@s.Description</td>
            <td>@(s.OltNom ?? "—")</td>
            <td class="text-muted" style="font-size:12px">@s.LaunchedByUserId</td>
            <td class="text-nowrap text-muted" style="font-size:12px">@s.DateLancement.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
          </tr>
          }
        </tbody>
      </table>
    </div>
  </div>
}
