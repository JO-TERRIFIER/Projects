@model BoitierEtageDisplayVM
@{ ViewData["Title"] = "Détails — " + Model.Nom; }
<div class="page-header d-flex justify-content-between align-items-center">
  <h1 class="page-title"><i class="bi bi-layers me-2"></i>@Model.Nom</h1>
  <div class="d-flex gap-2">
    @if (!User.IsInRole("Visiteur")) {
      <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-secondary"><i class="bi bi-pencil me-1"></i>Modifier</a>
      <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="d-inline">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash me-1"></i>Supprimer</button>
      </form>
    }
    <a asp-action="Index" asp-route-bpiId="@Model.BpiId" class="btn btn-sm btn-outline-secondary">
      <i class="bi bi-arrow-left me-1"></i>Retour
    </a>
  </div>
</div>
<div class="card shadow-sm" style="max-width:600px">
  <div class="card-body">
    <dl class="row">
      <dt class="col-sm-4">Nom</dt>
      <dd class="col-sm-8">@Model.Nom</dd>

      <dt class="col-sm-4">BPI parent</dt>
      <dd class="col-sm-8">
        <a asp-controller="Bpis" asp-action="Details" asp-route-id="@Model.BpiId">@Model.BpiNom</a>
      </dd>

      <dt class="col-sm-4">Étage</dt>
      <dd class="col-sm-8">Étage @Model.Etage</dd>

      <dt class="col-sm-4">Capacité</dt>
      <dd class="col-sm-8">@Model.Capacite ports</dd>

      <dt class="col-sm-4">Latitude</dt>
      <dd class="col-sm-8">@(Model.Latitude?.ToString("F6") ?? "—")</dd>

      <dt class="col-sm-4">Longitude</dt>
      <dd class="col-sm-8">@(Model.Longitude?.ToString("F6") ?? "—")</dd>

      <dt class="col-sm-4">Statut</dt>
      <dd class="col-sm-8">
        @if (Model.IsActive) { <span class="badge bg-success">Actif</span> }
        else { <span class="badge bg-danger">Inactif</span> }
      </dd>
    </dl>
  </div>
</div>
