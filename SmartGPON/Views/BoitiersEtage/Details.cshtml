@model SmartGPON.Web.ViewModels.BoitierEtageDisplayVM
@{ ViewData["Title"] = "Détails — " + Model.Nom; }

<div class="page-header">
  <div class="d-flex align-items-center justify-content-between mb-4">
    <div>
      <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-1">
          <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Accueil</a></li>
          <li class="breadcrumb-item"><a asp-controller="BoitiersEtage" asp-action="Index">Boîtiers d'étage</a></li>
          <li class="breadcrumb-item active">@Model.Nom</li>
        </ol>
      </nav>
      <h1 class="h4 mb-0 fw-500"><i class="bi bi-layers me-2"></i>@Model.Nom</h1>
    </div>
    @if (!User.IsInRole("Visiteur"))
    {
      <a asp-action="Edit" asp-route-id="@Model.Id" class="btn sg-btn sg-btn-outline">
        <i class="bi bi-pencil me-1"></i>Modifier
      </a>
    }
  </div>
</div>

<div class="page-body">
  <div class="sg-card" style="max-width:640px">
    <h2 class="h6 mb-3 fw-600"><i class="bi bi-info-circle me-2"></i>Informations</h2>
    <dl class="row mb-0">
      <dt class="col-5 text-muted small">BPI</dt>
      <dd class="col-7 small">@Model.BpiNom</dd>
      <dt class="col-5 text-muted small">Étage</dt>
      <dd class="col-7 small">@Model.Etage</dd>
      <dt class="col-5 text-muted small">Capacité</dt>
      <dd class="col-7 small">@Model.Capacite</dd>
      <dt class="col-5 text-muted small">Statut</dt>
      <dd class="col-7 small">
        @if (Model.IsActive)
        { <span class="badge-status status-online">Actif</span> }
        else
        { <span class="badge-status status-offline">Inactif</span> }
      </dd>
      <dt class="col-5 text-muted small">Latitude</dt>
      <dd class="col-7 small">@(Model.Latitude?.ToString("F4") ?? "—")</dd>
      <dt class="col-5 text-muted small">Longitude</dt>
      <dd class="col-7 small">@(Model.Longitude?.ToString("F4") ?? "—")</dd>
    </dl>
  </div>
</div>
