@model List<SmartGPON.Web.ViewModels.BoitierEtageDisplayVM>
@{ ViewData["Title"] = "Boîtiers d'étage"; }

<div class="page-header">
  <div class="d-flex align-items-center justify-content-between mb-4">
    <div>
      <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-1">
          <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Accueil</a></li>
          <li class="breadcrumb-item"><a asp-controller="Bpis" asp-action="Index">BPIs</a></li>
          <li class="breadcrumb-item active">Boîtiers d'étage</li>
        </ol>
      </nav>
      <h1 class="h4 mb-0 fw-500"><i class="bi bi-layers me-2"></i>Boîtiers d'étage</h1>
    </div>
    @if (!User.IsInRole("Visiteur"))
    {
      <a asp-action="Create" asp-route-bpiId="@ViewBag.BpiId" class="btn sg-btn sg-btn-primary">
        <i class="bi bi-plus me-1"></i>Nouveau boîtier
      </a>
    }
  </div>
</div>

<div class="page-body">
  <div class="sg-card">
    <div class="d-flex gap-2 mb-3">
      <input type="search" id="srch" class="form-control form-control-sm" placeholder="Rechercher…">
    </div>
    <table class="sg-table" id="tbl">
      <thead>
        <tr>
          <th>Nom</th>
          <th>BPI</th>
          <th>Étage</th>
          <th>Capacité</th>
          <th>Statut</th>
          <th style="width:120px">Actions</th>
        </tr>
      </thead>
      <tbody>
        @foreach (var item in Model)
        {
          <tr data-search="@item.Nom @item.BpiNom">
            <td class="fw-500">@item.Nom</td>
            <td class="text-muted">@item.BpiNom</td>
            <td>@item.Etage</td>
            <td>@item.Capacite</td>
            <td>
              @if (item.IsActive)
              { <span class="badge-status status-online">Actif</span> }
              else
              { <span class="badge-status status-offline">Inactif</span> }
            </td>
            <td>
              <div class="d-flex gap-1">
                <a asp-action="Details" asp-route-id="@item.Id"
                   class="btn sg-btn sg-btn-outline btn-sm"><i class="bi bi-eye"></i></a>
                @if (!User.IsInRole("Visiteur"))
                {
                  <a asp-action="Edit" asp-route-id="@item.Id" class="btn sg-btn sg-btn-outline btn-sm">
                    <i class="bi bi-pencil"></i>
                  </a>
                  <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn sg-btn sg-btn-danger btn-sm">
                      <i class="bi bi-trash"></i>
                    </button>
                  </form>
                }
              </div>
            </td>
          </tr>
        }
      </tbody>
    </table>
  </div>
</div>

@section Scripts {
<script>
const srch = document.getElementById('srch');
srch.addEventListener('input', () => {
  const s = srch.value.toLowerCase();
  document.querySelectorAll('#tbl tbody tr').forEach(r => {
    r.style.display = !s || r.dataset.search?.toLowerCase().includes(s) ? '' : 'none';
  });
});
</script>
}
