@model SmartGPON.Web.ViewModels.BoitierEtageCreateVM
@{ ViewData["Title"] = "Nouveau boîtier d'étage"; }

<link rel="stylesheet" href="~/css/gpon-modal.css" />

<div class="gpon-overlay">
  <div class="gpon-modal">
    <div class="gpon-modal-header">
      <h5><i class="bi bi-layers me-2"></i>Nouveau boîtier d'étage</h5>
      <a href="@Url.Action("Index", new { bpiId = Model.BpiId })" class="btn-close-modal">✕</a>
    </div>
    <div class="gpon-modal-body">
      <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()
        <input asp-for="BpiId" type="hidden" />
        <div class="row g-3">
          <div class="col-12">
            <label asp-for="Nom" class="form-label text-muted small mb-1">Nom <span class="text-danger">*</span></label>
            <input asp-for="Nom" class="form-control" placeholder="Ex: BE-R+2-01">
            <span asp-validation-for="Nom" class="text-danger small"></span>
          </div>
          <div class="col-md-6">
            <label asp-for="Etage" class="form-label text-muted small mb-1">Étage <span class="text-muted small">(0–99)</span></label>
            <input asp-for="Etage" class="form-control" type="number" min="0" max="99" placeholder="2">
            <span asp-validation-for="Etage" class="text-danger small"></span>
          </div>
          <div class="col-md-6">
            <label asp-for="Capacite" class="form-label text-muted small mb-1">Capacité <span class="text-muted small">(1–999)</span></label>
            <input asp-for="Capacite" class="form-control" type="number" min="1" max="999" placeholder="4">
            <span asp-validation-for="Capacite" class="text-danger small"></span>
          </div>
          <div class="col-md-6">
            <label asp-for="Latitude" class="form-label text-muted small mb-1">Latitude</label>
            <input asp-for="Latitude" class="form-control" placeholder="36.7372">
            <span asp-validation-for="Latitude" class="text-danger small"></span>
          </div>
          <div class="col-md-6">
            <label asp-for="Longitude" class="form-label text-muted small mb-1">Longitude</label>
            <input asp-for="Longitude" class="form-control" placeholder="3.0868">
            <span asp-validation-for="Longitude" class="text-danger small"></span>
          </div>
          <div class="col-12">
            <div class="form-check form-switch mt-1">
              <input asp-for="IsActive" class="form-check-input" type="checkbox" checked>
              <label asp-for="IsActive" class="form-check-label">Actif</label>
            </div>
          </div>
        </div>
        <div class="gpon-modal-footer">
          <a href="@Url.Action("Index", new { bpiId = Model.BpiId })" class="btn-cancel">Annuler</a>
          <button type="submit" class="btn sg-btn sg-btn-primary">
            <i class="bi bi-check2 me-1"></i>Enregistrer
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

@section Scripts {
  @if (!ViewData.ModelState.IsValid) {
    <script>document.querySelector('.gpon-modal')?.scrollIntoView({behavior:'smooth'});</script>
  }
}
