@model BoitierEtageUpdateVM
@{ ViewData["Title"] = "Modifier le boîtier d'étage"; }
<div class="page-header"><h1 class="page-title"><i class="bi bi-layers me-2"></i>Modifier le boîtier d'étage</h1></div>
<div class="card shadow-sm" style="max-width:600px">
  <div class="card-body">
    <form asp-action="Edit" method="post">
      @Html.AntiForgeryToken()
      <input type="hidden" asp-for="Id" />
      <input type="hidden" asp-for="BpiId" />
      <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
      <div class="mb-3">
        <label asp-for="Nom" class="form-label fw-semibold">Nom</label>
        <input asp-for="Nom" class="form-control" />
        <span asp-validation-for="Nom" class="text-danger small"></span>
      </div>
      <div class="row mb-3">
        <div class="col">
          <label asp-for="Etage" class="form-label fw-semibold">Étage</label>
          <input asp-for="Etage" type="number" min="0" max="99" class="form-control" />
          <span asp-validation-for="Etage" class="text-danger small"></span>
        </div>
        <div class="col">
          <label asp-for="Capacite" class="form-label fw-semibold">Capacité (ports)</label>
          <input asp-for="Capacite" type="number" min="1" class="form-control" />
          <span asp-validation-for="Capacite" class="text-danger small"></span>
        </div>
      </div>
      <div class="row mb-3">
        <div class="col">
          <label asp-for="Latitude" class="form-label fw-semibold">Latitude</label>
          <input asp-for="Latitude" class="form-control" />
        </div>
        <div class="col">
          <label asp-for="Longitude" class="form-label fw-semibold">Longitude</label>
          <input asp-for="Longitude" class="form-control" />
        </div>
      </div>
      <div class="mb-4 form-check">
        <input asp-for="IsActive" class="form-check-input" type="checkbox" />
        <label asp-for="IsActive" class="form-check-label">Actif</label>
      </div>
      <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>Enregistrer</button>
        <a asp-action="Index" asp-route-bpiId="@Model.BpiId" class="btn btn-outline-secondary">Annuler</a>
      </div>
    </form>
  </div>
</div>
