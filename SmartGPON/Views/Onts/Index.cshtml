@* Views/Onts/Index.cshtml *@
@model IEnumerable<SmartGPON.Core.Entities.Ont>
@{ ViewData["Title"] = "ONTs"; }

<div class="page-header">
    <div>
        <h1 class="page-title"><i class="bi bi-router me-2"></i>ONTs</h1>
        <div class="page-subtitle">Optical Network Terminals — Équipements abonnés</div>
    </div>
    <a asp-action="Create" class="btn-primary-sg"><i class="bi bi-plus-lg me-1"></i>Nouvel ONT</a>
</div>

<div class="page-body">
    <div class="sg-card">
        <table class="sg-table">
            <thead><tr><th>Numéro série</th><th>Nom</th><th>Adresse IP</th><th>Splitter</th><th>Signal Rx</th><th>Signal Tx</th><th>Statut</th><th>Actions</th></tr></thead>
            <tbody>
            @foreach (var n in Model)
            {
                var rxColor = n.SignalRx.HasValue ? (n.SignalRx > -26 ? "var(--accent-green)" : n.SignalRx > -30 ? "var(--accent-amber)" : "var(--accent-red)") : "var(--text-muted)";
                <tr>
                    <td><code class="mono text-accent" style="font-size:.8rem">@n.SerialNumber</code></td>
                    <td>@n.Nom</td>
                    <td><small style="color:var(--text-muted)">@n.IpAddress</small></td>
                    <td><small style="color:var(--text-muted)">@n.Splitter?.Nom</small></td>
                    <td><span style="color:@rxColor;font-weight:600">@(n.SignalRx.HasValue ? $"{n.SignalRx} dBm" : "—")</span></td>
                    <td><span style="color:var(--text-muted)">@(n.SignalTx.HasValue ? $"{n.SignalTx} dBm" : "—")</span></td>
                    <td>
                        @if(n.Statut == SmartGPON.Core.Enums.StatutEquipement.Actif)
                        {
                            <span class="pill pill-green"><span class="si si-on"></span>Actif</span>
                        }
                        else if(n.Statut == SmartGPON.Core.Enums.StatutEquipement.EnPanne)
                        {
                            <span class="pill pill-red"><span class="si si-err"></span>En panne</span>
                        }
                        else
                        {
                            <span class="pill pill-muted">@n.Statut</span>
                        }
                    </td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@n.Id" class="icon-btn edit" title="Modifier"><i class="bi bi-pencil"></i></a>
                        <form asp-action="Delete" asp-route-id="@n.Id" method="post" class="d-inline" onsubmit="return confirm('Supprimer cet ONT ?')">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="icon-btn danger" title="Supprimer"><i class="bi bi-trash"></i></button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
