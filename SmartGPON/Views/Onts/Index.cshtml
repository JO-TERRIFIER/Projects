@model IEnumerable<SmartGPON.Core.Entities.Ont>
@{ ViewData["Title"] = "ONTs"; }
<div class="page-header"><div><h1 class="page-title">ONTs</h1><div class="page-subtitle">Terminaux réseau optique — rattachés à FDT (villa) ou BPI (immeuble)</div></div><a asp-action="Create" class="btn-primary-sg"><i class="bi bi-plus-lg"></i> Nouvel ONT</a></div>
<div class="page-body"><div class="sg-card p-0" style="overflow:hidden"><div style="overflow-x:auto"><table class="sg-table">
  <thead><tr><th style="padding-left:20px">S/N</th><th>Nom</th><th>FDT</th><th>BPI</th><th>IP</th><th>Signal Rx/Tx</th><th>Statut</th><th style="padding-right:20px;text-align:right">Actions</th></tr></thead>
  <tbody>
  @foreach(var n in Model){
    var pill = n.Statut==SmartGPON.Core.Enums.StatutEquipement.Actif?"pill-green":n.Statut==SmartGPON.Core.Enums.StatutEquipement.EnPanne?"pill-red":"pill-amber";
    <tr><td style="padding-left:20px" class="mono" style="font-size:11px">@n.SerialNumber</td>
    <td style="font-weight:500;color:var(--text-primary)">@(n.Nom??"-")</td>
    <td style="font-size:12px;color:var(--text-muted)">@n.Fdt?.Nom</td>
    <td style="font-size:12px;color:var(--accent-cyan)">@(n.Bpi?.Nom ?? "—")</td>
    <td class="mono" style="font-size:11px">@(n.IpAddress??"-")</td>
    <td class="mono" style="font-size:11px">@(n.SignalRx.HasValue?$"{n.SignalRx:F1}/{n.SignalTx:F1}":"-")</td>
    <td><span class="pill @pill">@n.Statut</span></td>
    <td style="padding-right:20px;text-align:right"><div class="d-flex justify-content-end gap-1">
      <a asp-action="Edit" asp-route-id="@n.Id" class="icon-btn edit"><i class="bi bi-pencil"></i></a>
      <form asp-action="Delete" asp-route-id="@n.Id" method="post" class="d-inline" onsubmit="return confirm('Supprimer ?')">@Html.AntiForgeryToken()<button type="submit" class="icon-btn danger"><i class="bi bi-trash3"></i></button></form>
    </div></td></tr>
  }
  </tbody>
</table></div></div></div>
