@using SmartGPON.Core.Entities
@using SmartGPON.Core.Enums
@model Bpi
@{ ViewData["Title"] = "BPI — " + Model.Nom; }

<div class="page-header">
  <div class="d-flex align-items-center justify-content-between mb-4">
    <div>
      <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-1">
          <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Accueil</a></li>
          <li class="breadcrumb-item"><a asp-controller="Bpis" asp-action="Index">BPIs</a></li>
          <li class="breadcrumb-item active">@Model.Nom</li>
        </ol>
      </nav>
      <h1 class="h4 mb-0 fw-500"><i class="bi bi-diagram-2 me-2"></i>@Model.Nom</h1>
    </div>
    <div class="d-flex gap-2">
      <a asp-controller="BoitiersEtage" asp-action="Create" asp-route-bpiId="@Model.Id"
         class="btn sg-btn sg-btn-primary">
        <i class="bi bi-plus me-1"></i>Ajouter boîtier d'étage
      </a>
      <a asp-action="Edit" asp-route-id="@Model.Id" class="btn sg-btn sg-btn-outline">
        <i class="bi bi-pencil me-1"></i>Modifier
      </a>
    </div>
  </div>
</div>

<div class="page-body">
  <div class="row g-3 mb-4">
    <div class="col-lg-4">
      <div class="sg-card h-100">
        <h2 class="h6 mb-3 fw-600"><i class="bi bi-info-circle me-2"></i>Informations</h2>
        <dl class="row mb-0">
          <dt class="col-5 text-muted small">FDT</dt>
          <dd class="col-7 small">@(Model.Fdt?.Nom ?? "—")</dd>
          <dt class="col-5 text-muted small">OLT</dt>
          <dd class="col-7 small">@(Model.Fdt?.Olt?.Nom ?? "—")</dd>
          <dt class="col-5 text-muted small">Zone</dt>
          <dd class="col-7 small">@(Model.Fdt?.Olt?.Zone?.Nom ?? "—")</dd>
          <dt class="col-5 text-muted small">Capacité</dt>
          <dd class="col-7 small">@Model.Capacite</dd>
          <dt class="col-5 text-muted small">Latitude</dt>
          <dd class="col-7 small">@(Model.Latitude?.ToString("F4") ?? "—")</dd>
          <dt class="col-5 text-muted small">Longitude</dt>
          <dd class="col-7 small">@(Model.Longitude?.ToString("F4") ?? "—")</dd>
        </dl>
      </div>
    </div>
    <div class="col-lg-8">
      <div class="sg-card h-100">
        <div class="d-flex align-items-center justify-content-between mb-3">
          <h2 class="h6 mb-0 fw-600">
            <i class="bi bi-layers me-2"></i>Boîtiers d'étage
            <span class="badge-status status-online ms-2">@(Model.BoitiersEtage?.Count ?? 0)</span>
          </h2>
          <a asp-controller="BoitiersEtage" asp-action="Index" asp-route-bpiId="@Model.Id"
             class="btn sg-btn sg-btn-outline btn-sm">Voir tout</a>
        </div>
        @if (Model.BoitiersEtage?.Any() == true)
        {
          <table class="sg-table">
            <thead>
              <tr>
                <th>Nom</th>
                <th>Étage</th>
                <th>Capacité</th>
                <th>Statut</th>
                <th style="width:90px">Actions</th>
              </tr>
            </thead>
            <tbody>
              @foreach (var be in Model.BoitiersEtage)
              {
                <tr>
                  <td class="fw-500">@be.Nom</td>
                  <td>@be.Etage</td>
                  <td>@be.Capacite</td>
                  <td>
                    @if (be.IsActive)
                    { <span class="badge-status status-online">Actif</span> }
                    else
                    { <span class="badge-status status-offline">Inactif</span> }
                  </td>
                  <td>
                    <div class="d-flex gap-1">
                      <a asp-controller="BoitiersEtage" asp-action="Details" asp-route-id="@be.Id"
                         class="btn sg-btn sg-btn-outline btn-sm">
                        <i class="bi bi-eye"></i>
                      </a>
                    </div>
                  </td>
                </tr>
              }
            </tbody>
          </table>
        }
        else
        {
          <p class="text-muted small mb-0">Aucun boîtier d'étage enregistré.</p>
        }
      </div>
    </div>
  </div>
</div>
