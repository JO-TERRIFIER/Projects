@using SmartGPON.Core.Entities
@using SmartGPON.Core.Enums
@model Bpi
@{
    ViewData["Title"] = "Détails BPI — " + Model.Nom;
    var currentRole = User.IsInRole(UserRoles.Superviseur) ? UserRoles.Superviseur
                    : User.IsInRole(UserRoles.Visiteur) ? UserRoles.Visiteur
                    : UserRoles.Membre;
}
<div class="page-header d-flex justify-content-between align-items-center">
  <h1 class="page-title"><i class="bi bi-boxes me-2"></i>@Model.Nom</h1>
  <div class="d-flex gap-2">
    @if (currentRole != UserRoles.Visiteur) {
      <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-secondary">
        <i class="bi bi-pencil me-1"></i>Modifier
      </a>
    }
    <a asp-action="Index" asp-route-fdtId="@Model.FdtId" class="btn btn-sm btn-outline-secondary">
      <i class="bi bi-arrow-left me-1"></i>Retour
    </a>
  </div>
</div>

<div class="card shadow-sm mb-4" style="max-width:600px">
  <div class="card-body">
    <dl class="row mb-0">
      <dt class="col-sm-4">Nom</dt>
      <dd class="col-sm-8">@Model.Nom</dd>
      <dt class="col-sm-4">FDT</dt>
      <dd class="col-sm-8">@Model.Fdt?.Nom <span class="text-muted small">/ @Model.Fdt?.Olt?.Nom</span></dd>
      <dt class="col-sm-4">Capacité</dt>
      <dd class="col-sm-8">@Model.Capacite ports</dd>
      <dt class="col-sm-4">Latitude</dt>
      <dd class="col-sm-8">@(Model.Latitude?.ToString("F6") ?? "—")</dd>
      <dt class="col-sm-4">Longitude</dt>
      <dd class="col-sm-8">@(Model.Longitude?.ToString("F6") ?? "—")</dd>
    </dl>
  </div>
</div>

<section class="mt-4">
  <div class="d-flex align-items-center mb-2 gap-3">
    <h4 class="mb-0">
      <i class="bi bi-layers me-1"></i>Boîtiers d'étage
      <span class="badge bg-secondary ms-1">@Model.BoitiersEtage.Count</span>
    </h4>
    @if (currentRole != UserRoles.Visiteur) {
      <a asp-controller="BoitiersEtage" asp-action="Create" asp-route-bpiId="@Model.Id"
         class="btn btn-sm btn-primary">
        <i class="bi bi-plus-lg me-1"></i>Ajouter un boîtier d'étage
      </a>
    }
  </div>

  @if (!Model.BoitiersEtage.Any()) {
    <div class="alert alert-info">Aucun boîtier d'étage enregistré pour ce BPI.</div>
  } else {
    <div class="card shadow-sm">
      <div class="table-responsive">
        <table class="table table-sm table-hover mb-0">
          <thead class="table-light"><tr>
            <th>Nom</th><th>Étage</th><th>Capacité</th><th>Statut</th><th>Actions</th>
          </tr></thead>
          <tbody>
            @foreach (var be in Model.BoitiersEtage.OrderBy(b => b.Etage)) {
            <tr>
              <td class="fw-semibold">@be.Nom</td>
              <td>Étage @be.Etage</td>
              <td>@be.Capacite ports</td>
              <td>
                @if (be.IsActive) { <span class="badge bg-success">Actif</span> }
                else { <span class="badge bg-danger">Inactif</span> }
              </td>
              <td>
                <a asp-controller="BoitiersEtage" asp-action="Details" asp-route-id="@be.Id"
                   class="btn btn-xs btn-sm btn-outline-info me-1">Détails</a>
                @if (currentRole != UserRoles.Visiteur) {
                  <a asp-controller="BoitiersEtage" asp-action="Edit" asp-route-id="@be.Id"
                     class="btn btn-xs btn-sm btn-outline-secondary">Modifier</a>
                }
              </td>
            </tr>
            }
          </tbody>
        </table>
      </div>
    </div>
  }
</section>
