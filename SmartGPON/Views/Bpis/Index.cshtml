@model IEnumerable<SmartGPON.Core.Entities.Bpi>
@{ ViewData["Title"] = "BPIs"; }
<div class="page-header">
  <div><h1 class="page-title">BPIs</h1><div class="page-subtitle">Boîtier Pied Immeuble — capacité 24 ou 48 ports</div></div>
  <a asp-action="Create" class="btn-primary-sg"><i class="bi bi-plus-lg"></i> Nouveau BPI</a>
</div>
<div class="page-body"><div class="sg-card p-0" style="overflow:hidden"><div style="overflow-x:auto"><table class="sg-table">
  <thead><tr><th style="padding-left:20px">Nom</th><th>FDT parent</th><th>Capacité</th><th>Splitters 1:8</th><th>Coordonnées</th><th>Statut</th><th style="padding-right:20px;text-align:right">Actions</th></tr></thead>
  <tbody>
  @foreach(var b in Model){
    var pill = b.Statut==SmartGPON.Core.Enums.StatutEquipement.Actif?"pill-green":b.Statut==SmartGPON.Core.Enums.StatutEquipement.EnPanne?"pill-red":"pill-amber";
    <tr><td style="padding-left:20px;font-weight:500;color:var(--text-primary)" class="mono">@b.Nom</td>
    <td style="font-size:12px;color:var(--text-muted)">@b.Fdt?.Nom</td>
    <td><span class="pill pill-violet" style="font-size:10px">@b.Capacite ports</span></td>
    <td class="mono" style="color:var(--accent-cyan)">@b.NbSplitters1x8 × 1:8</td>
    <td class="mono" style="font-size:11px;color:var(--text-muted)">@(b.Latitude.HasValue ? $"{b.Latitude:F4}, {b.Longitude:F4}" : "—")</td>
    <td><span class="pill @pill">@b.Statut</span></td>
    <td style="padding-right:20px;text-align:right"><div class="d-flex justify-content-end gap-1">
      <a asp-action="Edit" asp-route-id="@b.Id" class="icon-btn edit"><i class="bi bi-pencil"></i></a>
      <form asp-action="Delete" asp-route-id="@b.Id" method="post" class="d-inline" onsubmit="return confirm('Supprimer ?')">@Html.AntiForgeryToken()<button type="submit" class="icon-btn danger"><i class="bi bi-trash3"></i></button></form>
    </div></td></tr>
  }
  </tbody>
</table></div></div></div>
