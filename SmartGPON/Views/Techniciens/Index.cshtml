@model IEnumerable<SmartGPON.Core.Entities.Technicien>
@{
  ViewData["Title"] = "Techniciens";
  var canWrite = User.IsInRole("Admin") || User.IsInRole("Technicien");
  var canDelete = User.IsInRole("Admin");
}
<div class="page-header"><div><h1 class="page-title">Performance techniciens</h1><div class="page-subtitle">Suivi activité &amp; indicateurs</div></div>
  @if (canWrite)
  {
    <a asp-action="Create" class="btn-primary-sg"><i class="bi bi-plus-lg"></i> Nouveau technicien</a>
  }
</div>
<div class="page-body"><div class="sg-card p-0" style="overflow:hidden"><div style="overflow-x:auto"><table class="sg-table">
  <thead><tr><th style="padding-left:20px">Technicien</th><th>Projet</th><th>Zone</th><th>Spécialité</th><th>Email</th><th>Téléphone</th><th>Statut</th><th style="padding-right:20px;text-align:right">Actions</th></tr></thead>
  <tbody>
  @foreach(var t in Model){
    var initials = ((t.Prenom?.Substring(0,1)??"")+(t.Nom.Substring(0,1))).ToUpper();
    <tr><td style="padding-left:20px">
      <div class="d-flex align-items-center gap-2">
        <div style="width:30px;height:30px;background:linear-gradient(135deg,rgba(0,200,224,.2),rgba(124,77,255,.2));border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:600;position:relative;flex-shrink:0">
          @initials
          <span style="position:absolute;bottom:0;right:0;width:8px;height:8px;background:@(t.IsActive?"var(--accent-green)":"var(--text-muted)");border-radius:50%;border:1.5px solid var(--navy-800)"></span>
        </div>
        <div><div style="font-size:13px;font-weight:500;color:var(--text-primary)">@t.Prenom @t.Nom</div></div>
      </div></td>
    <td style="font-size:12px;color:var(--text-muted)">@t.Projet?.Nom</td>
    <td style="font-size:12px;color:var(--text-muted)">@(t.Zone?.Nom ?? "—")</td>
    <td><span class="pill pill-muted" style="font-size:10px">@(t.Specialite??"—")</span></td>
    <td class="mono" style="font-size:11.5px;color:var(--text-muted)">@(t.Email??"—")</td>
    <td class="mono" style="font-size:11.5px;color:var(--text-muted)">@(t.Telephone??"—")</td>
    <td><span class="pill @(t.IsActive?"pill-green":"pill-muted")">@(t.IsActive?"Actif":"Inactif")</span></td>
    <td style="padding-right:20px;text-align:right"><div class="d-flex justify-content-end gap-1">
      @if (canWrite)
      {
        <a asp-action="Edit" asp-route-id="@t.Id" class="icon-btn edit"><i class="bi bi-pencil"></i></a>
      }
      @if (canDelete)
      {
        <form asp-action="Delete" asp-route-id="@t.Id" method="post" class="d-inline" onsubmit="return confirm('Supprimer ?')">@Html.AntiForgeryToken()<button type="submit" class="icon-btn danger"><i class="bi bi-trash3"></i></button></form>
      }
    </div></td></tr>
  }
  </tbody>
</table></div></div></div>
