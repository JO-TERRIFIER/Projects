@model SmartGPON.Core.Entities.Technicien
@{ ViewData["Title"] = (Model.Id==0?"Nouveau":"Modifier")+" technicien"; }
<div class="page-header"><div><h1 class="page-title">@ViewData["Title"]</h1></div><a asp-action="Index" class="btn-ghost-sg"><i class="bi bi-arrow-left"></i> Retour</a></div>
<div class="page-body"><div style="max-width:560px">
  <form asp-action="@(Model.Id==0?"Create":"Edit")" method="post">
    @Html.AntiForgeryToken()
    @if(Model.Id!=0){<input type="hidden" asp-for="Id"/>}
    <div class="form-section">
      <div class="form-section-header"><div class="sec-icon" style="background:rgba(0,200,224,.1)"><i class="bi bi-person-gear" style="color:var(--accent-cyan)"></i></div><span style="font-size:13px;font-weight:600">Informations technicien</span></div>
      <div class="form-section-body"><div class="row g-3">
        <div class="col-md-6"><label class="sg-label">Nom *</label><input asp-for="Nom" class="sg-input form-control" required/></div>
        <div class="col-md-6"><label class="sg-label">Prénom</label><input asp-for="Prenom" class="sg-input form-control"/></div>
        <div class="col-md-6"><label class="sg-label">Email</label><input asp-for="Email" type="email" class="sg-input form-control"/></div>
        <div class="col-md-6"><label class="sg-label">Téléphone</label><input asp-for="Telephone" class="sg-input form-control" placeholder="+216 XX XXX XXX"/></div>
        <div class="col-md-8"><label class="sg-label">Spécialité</label>
          <input asp-for="Specialite" class="sg-input form-control" list="specs" placeholder="Senior Tech. GPON…"/>
          <datalist id="specs"><option value="Senior Tech. GPON"/><option value="Maintenance FAT/FDT"/><option value="Installation ONT"/><option value="Supervision NOC"/></datalist></div>
        <div class="col-md-4"><label class="sg-label">Client</label>
          <select asp-for="ClientId" class="sg-input form-select">
            <option value="">-- Aucun --</option>
            @foreach(var c in ViewBag.Clients as List<SmartGPON.Core.Entities.Client>??new()){<option value="@c.Id">@c.Nom</option>}
          </select></div>
        <div class="col-12">
          <div class="form-check form-switch">
            <input asp-for="IsActive" class="form-check-input" type="checkbox" role="switch"/>
            <label class="form-check-label" asp-for="IsActive" style="font-size:13px;color:var(--text-secondary);margin-left:6px">Technicien actif</label>
          </div></div>
      </div></div></div>
    <div class="d-flex gap-2"><button type="submit" class="btn-primary-sg"><i class="bi bi-check-lg"></i> Enregistrer</button><a asp-action="Index" class="btn-ghost-sg">Annuler</a></div>
  </form>
</div></div>
