<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1"/>
  <title>@(ViewData["Title"] != null ? ViewData["Title"] + " — " : "")SmartGPON</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"/>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet"/>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/chartjs-adapter-date-fns/dist/chartjs-adapter-date-fns.bundle.min.js"></script>
  <link href="~/css/site.css" rel="stylesheet" asp-append-version="true" />
</head>
<body>
<script>if(localStorage.getItem('theme') === 'dark') document.body.classList.add('dark');</script>

@if (User.IsInRole("Visiteur"))
{
    <style>
        a[href*="/Create"], a[href*="/Edit"], form[action*="/Delete"],
        a[href*="/LancerSimulation"], form[action*="/AddAssignment"], form[action*="/RemoveAssignment"],
        a[href*="/Zones/Create"], a[href*="/Projets/Create"], a[href*="/Clients/Create"],
        button[type="submit"]:not(.user-drop-btn) {
            display: none !important;
        }
    </style>
}

@{
  var ctrl   = ViewContext.RouteData.Values["controller"]?.ToString()?.ToLower();
  var action = ViewContext.RouteData.Values["action"]?.ToString()?.ToLower();
  string Nav(string c, string? a = null) =>
      (ctrl == c.ToLower() && (a == null || action == a.ToLower())) ? "nav-link-sg active" : "nav-link-sg";
  var unread = ViewBag.UnreadAlerts as int?;
  var currentRole = User.IsInRole("Superviseur") ? "Superviseur" : (User.IsInRole("Visiteur") ? "Visiteur" : (User.IsInRole("Membre") ? "Membre" : "Utilisateur"));
}

<!-- -- TOPBAR -- -->
<header id="topbar">
  <button id="sidebar-toggle" onclick="toggleSidebar()"><i class="bi bi-list fs-5"></i></button>
  <a class="topbar-brand" asp-controller="Home" asp-action="Index">
    <div class="brand-icon"><i class="bi bi-diagram-3"></i></div>
    <span class="brand-name">Smart<span>GPON</span></span>
  </a>
  <span class="topbar-env ms-3">NOC v3</span>
  <div class="topbar-right">
    <button class="topbar-icon-btn me-2" style="color:var(--color-status-offline)" onclick="shutdownApp()" title="Quitter l'application">
      <i class="bi bi-power"></i>
    </button>
    <button class="topbar-icon-btn me-2" onclick="toggleTheme()" title="Basculer le thème (Clair/Sombre)">
      <i class="bi bi-moon" id="theme-icon"></i>
    </button>
    <a asp-controller="Notifications" asp-action="Index" class="topbar-icon-btn" title="Notifications">
      <i class="bi bi-bell"></i>
      @if (unread.HasValue && unread > 0) { <span class="notif-dot"></span> }
    </a>
    <div class="topbar-divider"></div>
    @if (User.Identity?.IsAuthenticated == true)
    {
      <div class="dropdown">
        <button class="user-drop-btn dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false" style="all:unset;display:flex;align-items:center;gap:8px;cursor:pointer;padding:4px 8px;border:1px solid var(--color-border);border-radius:4px;color:var(--color-text-main);width:100%;box-sizing:border-box;">
          <div class="user-avatar" style="width:24px;height:24px;background:var(--color-telecom-blue);border-radius:50%;display:flex;align-items:center;justify-content:center;color:#fff;font-size:10px;font-weight:bold;flex-shrink:0;">
            @(User.Identity.Name?.Substring(0,2).ToUpper() ?? "??")
          </div>
          <div style="flex-grow:1;display:flex;flex-direction:column;align-items:flex-start;">
            <div class="u-name" style="font-size:12px;font-weight:bold;">@User.Identity.Name</div>
            <div class="u-role" style="font-size:10px;color:var(--color-text-muted);">@currentRole</div>
          </div>
        </button>
        <ul class="dropdown-menu dropdown-menu-end shadow-sm" style="background:var(--color-bg-surface);border:1px solid var(--color-border);border-radius:4px;width:100%;min-width:0;margin-top:2px;padding:2px;box-sizing:border-box;">
          <li>
            <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
              @Html.AntiForgeryToken()
              <button type="submit" class="dropdown-item fw-bold d-flex align-items-center justify-content-center" style="color:var(--color-status-offline);font-size:12px;padding:4px 0;width:100%;border-radius:4px;transition:background-color 0.2s ease;" onmouseover="this.style.backgroundColor='rgba(239, 68, 68, 0.1)'" onmouseout="this.style.backgroundColor='transparent'">
                <i class="bi bi-box-arrow-right me-2" style="font-size:13px;"></i> Déconnexion
              </button>
            </form>
          </li>
        </ul>
      </div>
    }
  </div>
</header>

<!-- -- SIDEBAR -- -->
<nav id="sidebar">
  <div class="sidebar-section">
    <div class="sidebar-label">Supervision</div>
    <a asp-controller="Home" asp-action="Index" class="@Nav("home","index")">
      <span class="nav-icon"><i class="bi bi-speedometer2"></i></span>
      <span class="nav-text">Tableau de bord</span>
    </a>
    <a asp-controller="Home" asp-action="ArchitectureGpon" class="@Nav("home","architecturegpon")">
      <span class="nav-icon"><i class="bi bi-diagram-3"></i></span>
      <span class="nav-text">Architecture GPON</span>
    </a>
    <a asp-controller="Notifications" asp-action="Index" class="@Nav("notifications","index")">
      <span class="nav-icon"><i class="bi bi-bell"></i></span>
      <span class="nav-text">Notifications</span>
      @if (unread.HasValue && unread > 0)
      {
        <span class="nav-badge">@unread</span>
      }
    </a>
  </div>

  <div class="sidebar-section">
    <div class="sidebar-label">Gestion</div>
    <a asp-controller="Clients" asp-action="Index" class="@Nav("clients")">
      <span class="nav-icon"><i class="bi bi-building"></i></span>
      <span class="nav-text">Clients</span>
    </a>
    <a asp-controller="Projets" asp-action="Index" class="@Nav("projets")">
      <span class="nav-icon"><i class="bi bi-folder2-open"></i></span>
      <span class="nav-text">Projets</span>
    </a>
    <a asp-controller="Zones" asp-action="Index" class="@Nav("zones")">
      <span class="nav-icon"><i class="bi bi-geo-alt"></i></span>
      <span class="nav-text">Zones</span>
    </a>
    <a asp-controller="Olts" asp-action="Index" class="@Nav("olts")">
      <span class="nav-icon"><i class="bi bi-hdd-network"></i></span>
      <span class="nav-text">OLTs</span>
    </a>
    <a asp-controller="Fdts" asp-action="Index" class="@Nav("fdts")">
      <span class="nav-icon"><i class="bi bi-diagram-2"></i></span>
      <span class="nav-text">FDTs</span>
    </a>
    <a asp-controller="Fats" asp-action="Index" class="@Nav("fats")">
      <span class="nav-icon"><i class="bi bi-box"></i></span>
      <span class="nav-text">FATs</span>
    </a>
    <a asp-controller="Bpis" asp-action="Index" class="@Nav("bpis")">
      <span class="nav-icon"><i class="bi bi-boxes"></i></span>
      <span class="nav-text">BPIs</span>
    </a>
    <a asp-controller="BoitiersEtage" asp-action="Index" class="@Nav("boitiersEtage")">
      <span class="nav-icon"><i class="bi bi-layers"></i></span>
      <span class="nav-text">Boîtiers d'étage</span>
    </a>
  </div>

  <div class="sidebar-section">
    <div class="sidebar-label">Sécurité</div>
    <a asp-controller="Security" asp-action="Index" class="@Nav("security","index")">
      <span class="nav-icon"><i class="bi bi-shield-check"></i></span>
      <span class="nav-text">Centre sécurité</span>
    </a>
    <a asp-controller="Security" asp-action="Simulations" class="@Nav("security","simulations")">
      <span class="nav-icon"><i class="bi bi-activity"></i></span>
      <span class="nav-text">Simulations</span>
    </a>
    <a asp-controller="Security" asp-action="RogueOlts" class="@Nav("security","rogueolts")">
      <span class="nav-icon"><i class="bi bi-exclamation-diamond"></i></span>
      <span class="nav-text">Rogue OLTs</span>
    </a>

  </div>

  <div class="sidebar-footer">
    @if (User.IsInRole("Superviseur")) { <a asp-controller="Users" asp-action="Index" class="nav-link-sg" style="display:flex;align-items:center;gap:8px"><span class="nav-icon"><i class="bi bi-people"></i></span><span class="nav-text">Utilisateurs</span></a> }
    @if (!User.IsInRole("Visiteur")) { <a asp-controller="Approvals" asp-action="Index" class="nav-link-sg" style="display:flex;align-items:center;gap:8px"><span class="nav-icon"><i class="bi bi-check2-square"></i></span><span class="nav-text">Demandes</span></a> }
    @if (User.IsInRole("Superviseur")) { <a asp-controller="AuditLogs" asp-action="Index" class="nav-link-sg" style="display:flex;align-items:center;gap:8px"><span class="nav-icon"><i class="bi bi-journal-text"></i></span><span class="nav-text">Audit</span></a> }
  </div>
</nav>

<!-- -- MAIN -- -->
<main id="main">
  @* TempData toasts *@
  @if (TempData["Success"] != null)
  {
    <div class="sg-toast sg-toast-success toast-auto-dismiss">
      <i class="bi bi-check-circle-fill"></i> @TempData["Success"]
    </div>
  }
  @if (TempData["Error"] != null)
  {
    <div class="sg-toast sg-toast-error toast-auto-dismiss">
      <i class="bi bi-exclamation-circle-fill"></i> @TempData["Error"]
    </div>
  }

  @if (!ViewData.ModelState.IsValid)
  {
    <div class="alert alert-danger alert-dismissible fade show m-4 shadow-sm" role="alert" style="border-left: 5px solid var(--color-status-offline);">
      <div class="d-flex align-items-center gap-2 mb-2 fw-bold text-danger">
        <i class="bi bi-exclamation-triangle-fill"></i> L'opération ne peut pas aboutir. Veuillez corriger les erreurs ci-dessous :
      </div>
      <div asp-validation-summary="All" class="text-danger m-0" style="font-size: 13px;"></div>
      <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
  }

  @RenderBody()
</main>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
function toggleSidebar() { document.body.classList.toggle('collapsed'); }

async function shutdownApp() {
  if (!confirm('Voulez-vous vraiment fermer l\'application ?')) return;
  const shutdownToken = '@SmartGPON.Web.Controllers.ShutdownController.Token';
  document.body.innerHTML = '<div style="display:flex;align-items:center;justify-content:center;height:100vh;flex-direction:column;gap:16px;font-family:Inter,sans-serif;color:#fff;background:#111;"><i class="bi bi-power" style="font-size:64px;color:#ef4444;"></i><p style="font-size:20px;font-weight:600;">Fermeture en cours…</p></div>';
  try {
    await fetch('/Shutdown?token=' + encodeURIComponent(shutdownToken), { method: 'POST' });
  } catch (_) { /* normal — le serveur coupe la connexion en s'arrêtant */ }
}

// Auto-dismiss toast
document.querySelectorAll('.toast-auto-dismiss').forEach(t => setTimeout(() => t.style.opacity = '0', 3500));

// Tree toggle
function tToggle(nodeEl) {
  const group = nodeEl.closest('.tree-node-group');
  if (!group) return;
  const children = group.querySelector(':scope > .tree-children');
  const btn = nodeEl.querySelector('.tree-toggle');
  const icon = btn?.querySelector('i');
  if (!children) return;
  const open = children.classList.toggle('open');
  btn?.classList.toggle('open', open);
  if (icon) icon.className = open ? 'bi bi-dash' : 'bi bi-plus';
}

// Dark Mode Toggle
function toggleTheme() {
  const isDark = document.body.classList.toggle('dark');
  localStorage.setItem('theme', isDark ? 'dark' : 'light');
  updateThemeIcon(isDark);
}
function updateThemeIcon(isDark) {
  const icon = document.getElementById('theme-icon');
  if (icon) {
    icon.className = isDark ? 'bi bi-sun' : 'bi bi-moon';
  }
}
updateThemeIcon(document.body.classList.contains('dark'));
// Enforce delete reason for all delete forms (used by RBAC/audit workflow)
document.addEventListener('submit', function (e) {
  const form = e.target;
  if (!(form instanceof HTMLFormElement)) return;
  if (!/\/Delete/i.test(form.action)) return;

  let reasonInput = form.querySelector('input[name="reason"]');
  if (!reasonInput) {
    reasonInput = document.createElement('input');
    reasonInput.type = 'hidden';
    reasonInput.name = 'reason';
    form.appendChild(reasonInput);
  }
  if (!reasonInput.value) {
    const reason = prompt('Raison obligatoire pour cette suppression:');
    if (!reason || !reason.trim()) {
      e.preventDefault();
      return;
    }
    reasonInput.value = reason.trim();
  }
});
</script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>






