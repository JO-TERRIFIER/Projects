@model List<ApprovalRequestDisplayVM>
@{ ViewData["Title"] = "Demandes d'approbation"; }
<div class="page-header"><h1 class="page-title"><i class="bi bi-check2-square me-2"></i>Demandes d'approbation</h1></div>
@if (!Model.Any()) {
  <div class="alert alert-info">Aucune demande.</div>
} else {
  <div class="card shadow-sm">
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead class="table-light"><tr>
          <th>Type cible</th><th>Action</th><th>Demandeur</th><th>Projet</th><th>Statut</th><th class="text-end">Actions</th>
        </tr></thead>
        <tbody>
          @foreach (var r in Model) {
          var badge = r.Status == 0 ? "warning" : (r.Status == 1 ? "success" : "danger");
          var label = r.Status == 0 ? "En attente" : (r.Status == 1 ? "Approuvé" : "Refusé");
          <tr>
            <td><span class="badge bg-light text-dark border">@r.TargetType</span></td>
            <td><span class="badge bg-secondary">@r.ActionType</span></td>
            <td style="font-size:12px">@r.RequestedByUserId</td>
            <td style="font-size:12px">@r.ProjetId</td>
            <td><span class="badge bg-@badge">@label</span></td>
            <td class="text-end">
              @if (r.Status == 0 && !User.IsInRole("Visiteur")) {
                <form asp-action="Approve" asp-route-id="@r.Id" method="post" class="d-inline">
                  @Html.AntiForgeryToken()
                  <button type="submit" class="btn btn-sm btn-success me-1"><i class="bi bi-check-lg"></i></button>
                </form>
                <form asp-action="Reject" asp-route-id="@r.Id" method="post" class="d-inline">
                  @Html.AntiForgeryToken()
                  <button type="submit" class="btn btn-sm btn-danger"><i class="bi bi-x-lg"></i></button>
                </form>
              }
            </td>
          </tr>
          }
        </tbody>
      </table>
    </div>
  </div>
}
