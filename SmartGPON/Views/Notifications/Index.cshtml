@model List<AuditLogDisplayVM>
@{ ViewData["Title"] = "Notifications"; }

<div class="page-header d-flex justify-content-between align-items-center">
  <h1 class="page-title"><i class="bi bi-bell me-2"></i>Notifications</h1>
</div>

@if (!Model.Any())
{
  <div class="alert alert-info"><i class="bi bi-info-circle me-2"></i>Aucune notification récente.</div>
}
else
{
  <div class="card shadow-sm">
    <div class="card-body p-0">
      <div class="list-group list-group-flush">
        @foreach (var n in Model)
        {
          <div class="list-group-item d-flex align-items-start gap-3 py-3">
            <div class="mt-1">
              <i class="bi bi-circle-fill text-primary" style="font-size:8px"></i>
            </div>
            <div class="flex-grow-1">
              <div class="fw-semibold" style="font-size:13px">
                <span class="badge bg-secondary me-1">@n.ActionType</span>
                <span class="badge bg-light text-dark border me-1">@n.EntityType</span>
                @if (!string.IsNullOrEmpty(n.NomTech))
                {
                  <span class="text-muted">— @n.PrenomTech @n.NomTech</span>
                }
              </div>
              <div class="text-muted" style="font-size:12px">@n.Description</div>
            </div>
            <div class="text-muted text-nowrap" style="font-size:11px">
              @n.OccurredAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
            </div>
          </div>
        }
      </div>
    </div>
  </div>
}
