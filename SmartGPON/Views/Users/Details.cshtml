@model SmartGPON.Web.ViewModels.UserDetailsViewModel
@{ ViewData["Title"] = "Détails du compte"; }

<div class="page-header">
    <div>
        <h1 class="page-title"><i class="bi bi-person-vcard me-2"></i>@ViewData["Title"]</h1>
        <div class="page-subtitle">Informations du compte utilisateur</div>
    </div>
    <a asp-action="Index" class="btn-ghost-sg"><i class="bi bi-arrow-left me-1"></i>Retour</a>
</div>

<div class="page-body">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="sg-card">
                <div class="row g-3">
                    <div class="col-12">
                        <div class="sg-label">Email</div>
                        <div class="mono">@Model.Email</div>
                    </div>
                    <div class="col-md-6">
                        <div class="sg-label">Rôle</div>
                        <span class="pill pill-cyan">@Model.Role</span>
                    </div>
                    <div class="col-md-6">
                        <div class="sg-label">Statut</div>
                        <span class="pill @(Model.IsActive ? "pill-green" : "pill-red")">@(Model.IsActive ? "Actif" : "Inactif")</span>
                    </div>
                    <div class="col-12">
                        <div class="sg-label">Email confirmé</div>
                        <span class="pill @(Model.EmailConfirmed ? "pill-green" : "pill-amber")">@(Model.EmailConfirmed ? "Oui" : "Non")</span>
                    </div>
                </div>
                <div class="d-flex gap-2 mt-4">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-primary-sg"><i class="bi bi-pencil me-1"></i>Modifier</a>
                    <a asp-action="Index" class="btn-ghost-sg">Fermer</a>
                </div>
            </div>
        </div>
    </div>
</div>
