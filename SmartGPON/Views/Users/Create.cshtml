@model SmartGPON.Web.ViewModels.UserCreateViewModel
@{ ViewData["Title"] = "Nouveau compte utilisateur"; }

<div class="page-header">
    <div>
        <h1 class="page-title"><i class="bi bi-person-plus me-2"></i>@ViewData["Title"]</h1>
        <div class="page-subtitle">Création d'un compte par l'administrateur</div>
    </div>
    <a asp-action="Index" class="btn-ghost-sg"><i class="bi bi-arrow-left me-1"></i>Retour</a>
</div>

<div class="page-body">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="sg-card">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="sg-label">Email *</label>
                            <input asp-for="Email" class="sg-input" type="email" required />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="sg-label">Mot de passe *</label>
                            <input asp-for="Password" class="sg-input" type="password" required />
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="sg-label">Confirmation *</label>
                            <input asp-for="ConfirmPassword" class="sg-input" type="password" required />
                            <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="sg-label">Rôle *</label>
                            <select asp-for="Role" class="sg-select" required>
                                <option value="">-- Sélectionner --</option>
                                @foreach (var role in Model.AvailableRoles)
                                {
                                    <option value="@role">@role</option>
                                }
                            </select>
                            <span asp-validation-for="Role" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 d-flex align-items-end">
                            <div class="form-check mb-2">
                                <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                                <label class="form-check-label" style="color:var(--text-secondary)">Compte actif</label>
                            </div>
                        </div>
                    </div>
                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn-primary-sg"><i class="bi bi-check-lg me-1"></i>Créer</button>
                        <a asp-action="Index" class="btn-ghost-sg">Annuler</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
