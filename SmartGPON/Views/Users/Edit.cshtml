@model SmartGPON.Web.ViewModels.UserEditViewModel
@{ ViewData["Title"] = "Modifier compte utilisateur"; }

<link rel="stylesheet" href="~/css/gpon-modal.css" />

<div class="gpon-overlay">
  <div class="gpon-modal">
    <div class="gpon-modal-header">
      <h5><i class="bi bi-pencil me-2"></i>Modifier compte utilisateur</h5>
      <a href="@Url.Action("Index")" class="btn-close-modal">✕</a>
    </div>
    <div class="gpon-modal-body">
      <form asp-action="Edit" method="post">
        @Html.AntiForgeryToken()
        <input asp-for="Id" type="hidden" />
        <div class="row g-3">
          <div class="col-md-6">
            <label asp-for="FirstName" class="form-label text-muted small mb-1">Prénom <span class="text-danger">*</span></label>
            <input asp-for="FirstName" class="form-control">
            <span asp-validation-for="FirstName" class="text-danger small"></span>
          </div>
          <div class="col-md-6">
            <label asp-for="LastName" class="form-label text-muted small mb-1">Nom <span class="text-danger">*</span></label>
            <input asp-for="LastName" class="form-control">
            <span asp-validation-for="LastName" class="text-danger small"></span>
          </div>
          <div class="col-12">
            <label asp-for="Email" class="form-label text-muted small mb-1">Email <span class="text-danger">*</span></label>
            <input asp-for="Email" class="form-control" type="email">
            <span asp-validation-for="Email" class="text-danger small"></span>
          </div>
          <div class="col-md-6">
            <label asp-for="Role" class="form-label text-muted small mb-1">Rôle <span class="text-danger">*</span></label>
            <select asp-for="Role" class="form-select">
              @if (Model.AvailableRoles.Any())
              {
                foreach (var r in Model.AvailableRoles)
                {
                  <option value="@r">@r</option>
                }
              }
              else
              {
                <option value="Superviseur">Superviseur</option>
                <option value="Membre">Membre</option>
                <option value="Visiteur">Visiteur</option>
              }
            </select>
            <span asp-validation-for="Role" class="text-danger small"></span>
          </div>
          <div class="col-md-6">
            <label asp-for="Specialite" class="form-label text-muted small mb-1">Spécialité</label>
            <input asp-for="Specialite" class="form-control">
          </div>
          <div class="col-12">
            <div class="form-check form-switch mt-1">
              <input asp-for="IsActive" class="form-check-input" type="checkbox">
              <label asp-for="IsActive" class="form-check-label">Compte actif</label>
            </div>
          </div>
          <div class="col-12">
            <div class="border-top pt-3 mt-1">
              <label class="form-label text-muted small mb-1">Nouveau mot de passe <span class="text-muted">(laisser vide pour ne pas changer)</span></label>
              <input asp-for="NewPassword" class="form-control" type="password" placeholder="••••••••">
              <span asp-validation-for="NewPassword" class="text-danger small"></span>
            </div>
          </div>
        </div>
        <div class="gpon-modal-footer">
          <a href="@Url.Action("Index")" class="btn-cancel">Annuler</a>
          <button type="submit" class="btn sg-btn sg-btn-primary">
            <i class="bi bi-check2 me-1"></i>Enregistrer
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

@section Scripts {
  @if (!ViewData.ModelState.IsValid) {
    <script>document.querySelector('.gpon-modal')?.scrollIntoView({behavior:'smooth'});</script>
  }
}
