@model SmartGPON.Web.ViewModels.UserEditViewModel
@{ ViewData["Title"] = "Modifier compte utilisateur"; }

<div class="page-header">
    <div>
        <h1 class="page-title"><i class="bi bi-person-gear me-2"></i>@ViewData["Title"]</h1>
        <div class="page-subtitle">Modification du compte, rôle et affectations projet</div>
    </div>
    <a asp-action="Index" class="btn-ghost-sg"><i class="bi bi-arrow-left me-1"></i>Retour</a>
</div>

<div class="page-body">
    <div class="row g-3 justify-content-center">
        <div class="col-md-8">
            <div class="sg-card">
                <form asp-action="Edit" method="post">
                    @Html.AntiForgeryToken()
                    <input asp-for="Id" type="hidden" />
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>
                    <div class="row g-3">
                        <div class="col-md-5">
                            <label class="sg-label">Nom *</label>
                            <input asp-for="LastName" class="sg-input" required />
                            <span asp-validation-for="LastName" class="text-danger small"></span>
                        </div>
                        <div class="col-md-5">
                            <label class="sg-label">Prénom *</label>
                            <input asp-for="FirstName" class="sg-input" required />
                            <span asp-validation-for="FirstName" class="text-danger small"></span>
                        </div>
                        <div class="col-md-8">
                            <label class="sg-label">Email *</label>
                            <input asp-for="Email" class="sg-input" type="email" required />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label class="sg-label">Rôle *</label>
                            <select asp-for="Role" class="sg-select" required>
                                @foreach (var role in Model.AvailableRoles)
                                {
                                    <option value="@role">@role</option>
                                }
                            </select>
                            <span asp-validation-for="Role" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label class="sg-label">Nouveau mot de passe</label>
                            <input asp-for="NewPassword" class="sg-input" type="password" />
                            <span asp-validation-for="NewPassword" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="sg-label">Confirmation nouveau mot de passe</label>
                            <input asp-for="ConfirmNewPassword" class="sg-input" type="password" />
                            <span asp-validation-for="ConfirmNewPassword" class="text-danger small"></span>
                        </div>

                        <div class="col-12">
                            <div class="form-check mt-1">
                                <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                                <label class="form-check-label" style="color:var(--text-secondary)">Compte actif</label>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn-primary-sg"><i class="bi bi-check-lg me-1"></i>Enregistrer</button>
                        <a asp-action="Index" class="btn-ghost-sg">Annuler</a>
                    </div>
                </form>
            </div>
        </div>

        <div class="col-md-8">
            <div class="sg-card">
                <h6 class="mb-3">Affectations projets</h6>
                <form asp-action="AddAssignment" method="post" class="row g-2 align-items-end">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="userId" value="@Model.Id" />
                    <div class="col-md-5">
                        <label class="sg-label">Projet</label>
                        <select name="projetId" class="sg-select" required>
                            <option value="">-- Sélectionner --</option>
                            @foreach (var p in (IEnumerable<SmartGPON.Core.Entities.Projet>)(ViewBag.Projets ?? new List<SmartGPON.Core.Entities.Projet>()))
                            {
                                <option value="@p.Id">@p.Nom</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="sg-label">Type</label>
                        <select name="assignmentType" class="sg-select" required>
                            <option value="ChefProjet">ChefProjet</option>
                            <option value="TechTerrain">TechTerrain</option>
                            <option value="TechDessin">TechDessin</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <button type="submit" class="btn-primary-sg w-100">Affecter</button>
                    </div>
                </form>

                <div class="mt-3" style="max-height:260px;overflow:auto">
                    <table class="sg-table">
                        <thead><tr><th>Projet</th><th>Type</th><th></th></tr></thead>
                        <tbody>
                        @foreach (var a in (IEnumerable<SmartGPON.Core.Entities.UserProjectAssignment>)(ViewBag.Assignments ?? new List<SmartGPON.Core.Entities.UserProjectAssignment>()))
                        {
                            <tr>
                                <td>@a.ProjetId</td>
                                <td>@a.AssignmentType</td>
                                <td style="text-align:right">
                                    <form asp-action="RemoveAssignment" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@a.Id" />
                                        <input type="hidden" name="userId" value="@Model.Id" />
                                        <button class="icon-btn danger" type="submit" title="Retirer"><i class="bi bi-x"></i></button>
                                    </form>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
