@* ── Views/Resources/Edit.cshtml ──────────────────────────────
   P10 · A5: NomFichier uniquement éditable
   Modèle: ResourceRenameVM
   CheminFichier jamais affiché / jamais bindé
*@
@model SmartGPON.Web.ViewModels.ResourceRenameVM
@{ ViewData["Title"] = "Renommer le fichier"; }

<link rel="stylesheet" href="~/css/gpon-modal.css" />

<div class="gpon-overlay">
  <div class="gpon-modal">
    <div class="gpon-modal-header">
      <h5><i class="bi bi-pencil me-2"></i>Renommer le fichier</h5>
      <a href="@Url.Action("Index", new { projetId = Model.ProjetId })"
         class="btn-close-modal">✕</a>
    </div>
    <div class="gpon-modal-body">
      <form asp-action="Edit" method="post">
        @Html.AntiForgeryToken()
        <input asp-for="Id" type="hidden" />
        <input asp-for="ProjetId" type="hidden" />

        <div class="row g-3">

          {{-- NomFichier: seule propriété éditable (A5) --}}
          <div class="col-12">
            <label asp-for="NomFichier" class="form-label text-muted small mb-1">
              Nom du fichier <span class="text-danger">*</span>
            </label>
            <input asp-for="NomFichier" class="form-control" autofocus />
            <span asp-validation-for="NomFichier" class="text-danger small"></span>
          </div>

          {{-- Métadonnées en lecture seule (non-bindées) --}}
          <div class="col-6">
            <label class="form-label text-muted small mb-1">Extension</label>
            <input class="form-control" value="@ViewBag.FileExtension" readonly disabled />
          </div>
          <div class="col-6">
            <label class="form-label text-muted small mb-1">Taille</label>
            <input class="form-control" value="@(ViewBag.FileSize is long s ? (s >= 1024*1024 ? $"{s/(1024.0*1024):F1} MB" : $"{s/1024.0:F1} KB") : "—")" readonly disabled />
          </div>
          <div class="col-12">
            <label class="form-label text-muted small mb-1">Type MIME</label>
            <input class="form-control" value="@ViewBag.ContentType" readonly disabled />
          </div>
          <div class="col-12">
            <label class="form-label text-muted small mb-1">Uploadé le</label>
            <input class="form-control" value="@(ViewBag.UploadedAt is DateTime d ? d.ToLocalTime().ToString("dd/MM/yyyy HH:mm") : "—")" readonly disabled />
          </div>

        </div>

        <div class="gpon-modal-footer">
          <a href="@Url.Action("Index", new { projetId = Model.ProjetId })"
             class="btn-cancel">Annuler</a>
          <button type="submit" class="btn sg-btn sg-btn-primary">
            <i class="bi bi-check2 me-1"></i>Enregistrer
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

@section Scripts {
  @if (!ViewData.ModelState.IsValid) {
    <script>document.querySelector('.gpon-modal')?.scrollIntoView({behavior:'smooth'});</script>
  }
}
