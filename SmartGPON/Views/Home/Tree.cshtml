@model List<Zone>
@{ ViewData["Title"] = "Architecture GPON"; }
<div class="page-header"><h1 class="page-title"><i class="bi bi-diagram-3 me-2"></i>Architecture GPON</h1></div>
<div class="tree-root">
  @foreach (var zone in Model) {
    <div class="tree-node-group mb-2">
      <div class="tree-node d-flex align-items-center gap-2 p-2" onclick="tToggle(this)" style="cursor:pointer;background:var(--color-bg-surface);border:1px solid var(--color-border);border-radius:4px;">
        <button type="button" class="tree-toggle btn btn-sm btn-outline-secondary p-0" style="width:22px;height:22px;line-height:1"><i class="bi bi-plus" style="font-size:11px"></i></button>
        <i class="bi bi-geo-alt text-warning"></i>
        <span class="fw-semibold">@zone.Nom</span>
        <small class="text-muted ms-2">Zone</small>
      </div>
      <div class="tree-children" style="margin-left:24px">
        @foreach (var olt in zone.Olts) {
          <div class="tree-node-group mt-1">
            <div class="tree-node d-flex align-items-center gap-2 p-2" onclick="tToggle(this)" style="cursor:pointer;background:var(--color-bg-surface);border:1px solid var(--color-border);border-radius:4px;">
              <button type="button" class="tree-toggle btn btn-sm btn-outline-secondary p-0" style="width:22px;height:22px;line-height:1"><i class="bi bi-plus" style="font-size:11px"></i></button>
              <i class="bi bi-hdd-network text-info"></i>
              <span class="fw-semibold">@olt.Nom</span>
              @if (!string.IsNullOrEmpty(olt.IpAddress)) {
                <code class="text-muted ms-1" style="font-size:11px">@olt.IpAddress</code>
              }
              <small class="text-muted ms-2">OLT — @olt.NbrePorts ports</small>
            </div>
            <div class="tree-children" style="margin-left:24px">
              @foreach (var fdt in olt.Fdts) {
                <div class="tree-node-group mt-1">
                  <div class="tree-node d-flex align-items-center gap-2 p-2" onclick="tToggle(this)" style="cursor:pointer;background:var(--color-bg-surface);border:1px solid var(--color-border);border-radius:4px;">
                    <button type="button" class="tree-toggle btn btn-sm btn-outline-secondary p-0" style="width:22px;height:22px;line-height:1"><i class="bi bi-plus" style="font-size:11px"></i></button>
                    <i class="bi bi-diagram-2 text-primary"></i>
                    <span class="fw-semibold">@fdt.Nom</span>
                    <small class="text-muted ms-2">FDT — @fdt.Splitters.Count splitters</small>
                  </div>
                  <div class="tree-children" style="margin-left:24px">
                    @foreach (var fat in fdt.Fats) {
                      <div class="tree-node d-flex align-items-center gap-2 p-1 mt-1" style="background:var(--color-bg-surface);border:1px solid var(--color-border);border-radius:4px;">
                        <i class="bi bi-box text-success"></i>
                        <span>@fat.Nom</span>
                        <small class="text-muted">FAT — cap. @fat.Capacite</small>
                      </div>
                    }
                    @foreach (var bpi in fdt.Bpis) {
                      <div class="tree-node d-flex align-items-center gap-2 p-1 mt-1" style="background:var(--color-bg-surface);border:1px solid var(--color-border);border-radius:4px;">
                        <i class="bi bi-boxes text-secondary"></i>
                        <span>@bpi.Nom</span>
                        <small class="text-muted">BPI — cap. @bpi.Capacite</small>
                      </div>
                    }
                  </div>
                </div>
              }
            </div>
          </div>
        }
      </div>
    </div>
  }
</div>
