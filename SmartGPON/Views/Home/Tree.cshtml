@model IEnumerable<SmartGPON.Core.Entities.Client>
@{ ViewData["Title"] = "Topologie réseau"; }
<div class="page-header">
  <div><h1 class="page-title">Topologie réseau</h1><div class="page-subtitle">Hiérarchie Client → Projet → Zone → OLT → FDT → FAT → Splitter → ONT</div></div>
  <div class="d-flex gap-2">
    <button class="btn-ghost-sg" onclick="expandAll()"><i class="bi bi-arrows-expand"></i> Tout déplier</button>
    <button class="btn-ghost-sg" onclick="collapseAll()"><i class="bi bi-arrows-collapse"></i> Tout replier</button>
  </div>
</div>
<div class="page-body"><div class="row g-3">
  <div class="col-xl-8">
    <div class="sg-card" id="tree-panel">
      @if(Model == null || !Model.Any()){
        <div class="text-center py-5" style="color:var(--text-muted)"><i class="bi bi-diagram-3 fs-1 d-block mb-3"></i>Aucune donnée réseau disponible</div>
      }
      @foreach(var client in Model ?? new List<SmartGPON.Core.Entities.Client>()){
        <div class="tree-node-group">
          <div class="tree-node" onclick="tToggle(this)">
            <span class="tree-toggle"><i class="bi bi-dash"></i></span>
            <span class="tree-icon" style="background:rgba(124,77,255,.15)"><i class="bi bi-building" style="color:#a78bff"></i></span>
            <span class="tree-label">@client.Nom</span>
            <span class="lbadge lvl-client ms-2">Client</span>
            <span class="si si-on ms-2"></span>
          </div>
          <div class="tree-children open"><div class="tree-connector">
            @foreach(var projet in client.Projets){
              <div class="tree-node-group">
                <div class="tree-node" onclick="tToggle(this)">
                  <span class="tree-toggle"><i class="bi bi-dash"></i></span>
                  <span class="tree-icon" style="background:rgba(0,200,224,.12)"><i class="bi bi-folder2-open" style="color:var(--accent-cyan)"></i></span>
                  <span class="tree-label">@projet.Nom</span>
                  <span class="lbadge lvl-projet ms-2">Projet</span>
                </div>
                <div class="tree-children open"><div class="tree-connector">
                  @foreach(var zone in projet.Zones){
                    <div class="tree-node-group">
                      <div class="tree-node" onclick="tToggle(this)">
                        <span class="tree-toggle"><i class="bi bi-dash"></i></span>
                        <span class="tree-icon" style="background:rgba(0,230,118,.1)"><i class="bi bi-geo-alt" style="color:var(--accent-green)"></i></span>
                        <span class="tree-label">@zone.Nom</span>
                        <span class="lbadge lvl-zone ms-2">Zone</span>
                      </div>
                      <div class="tree-children open"><div class="tree-connector">
                        @foreach(var olt in zone.Olts){
                          var oltSi = olt.Statut==SmartGPON.Core.Enums.StatutEquipement.Actif?"si-on":olt.Statut==SmartGPON.Core.Enums.StatutEquipement.EnPanne?"si-err":"si-warn";
                          <div class="tree-node-group">
                            <div class="tree-node" onclick="tToggle(this)">
                              <span class="tree-toggle"><i class="bi bi-plus"></i></span>
                              <span class="tree-icon" style="background:rgba(255,179,0,.1)"><i class="bi bi-server" style="color:var(--accent-amber)"></i></span>
                              <span class="tree-label">@olt.Nom @(olt.Marque!=null?"("+olt.Marque+" "+olt.Modele+")":"")</span>
                              <span class="lbadge lvl-olt ms-2">OLT</span>
                              <span class="si @oltSi ms-2"></span>
                            </div>
                            <div class="tree-children"><div class="tree-connector">
                              @foreach(var fdt in olt.Fdts){
                                <div class="tree-node-group">
                                  <div class="tree-node" onclick="tToggle(this)">
                                    <span class="tree-toggle"><i class="bi bi-plus"></i></span>
                                    <span class="tree-icon" style="background:rgba(255,255,255,.06)"><i class="bi bi-box" style="color:var(--text-secondary)"></i></span>
                                    <span class="tree-label">@fdt.Nom</span>
                                    <span class="lbadge lvl-fdt ms-2">FDT</span>
                                  </div>
                                  <div class="tree-children"><div class="tree-connector">
                                    @foreach(var fat in fdt.Fats){
                                      var onts = fat.Splitters?.SelectMany(s=>s.Onts??new List<SmartGPON.Core.Entities.Ont>()).Count()??0;
                                      var pct  = fat.Capacite>0?Math.Min(100,onts*100/fat.Capacite):0;
                                      var fColor= pct>=100?"var(--accent-red)":pct>=80?"var(--accent-amber)":"var(--accent-green)";
                                      <div class="tree-node-group">
                                        <div class="tree-node @(pct>=100?"":"")">
                                          <span class="tree-toggle"><i class="bi bi-plus"></i></span>
                                          <span class="tree-icon" style="background:rgba(0,230,118,.08)"><i class="bi bi-hdd-network" style="color:@fColor"></i></span>
                                          <span class="tree-label @(pct>=100?"text-r":"")">@fat.Nom</span>
                                          <span class="lbadge lvl-fat ms-2">FAT</span>
                                          <span class="si @(pct>=100?"si-err":pct>=80?"si-warn":"si-on") ms-2"></span>
                                          <div style="display:flex;align-items:center;gap:6px;margin-left:auto">
                                            <span style="font-size:10.5px;color:@fColor">@onts/@fat.Capacite</span>
                                            <div class="cap-bar"><div class="cap-fill" style="width:@pct%;background:@fColor"></div></div>
                                          </div>
                                        </div>
                                        <div class="tree-children"><div class="tree-connector">
                                          @foreach(var sp in fat.Splitters??new List<SmartGPON.Core.Entities.Splitter>()){
                                            @foreach(var ont in sp.Onts??new List<SmartGPON.Core.Entities.Ont>()){
                                              var oSi = ont.Statut==SmartGPON.Core.Enums.StatutEquipement.Actif?"si-on":ont.Statut==SmartGPON.Core.Enums.StatutEquipement.EnPanne?"si-err":"si-warn";
                                              <div class="tree-node">
                                                <span class="tree-spacer"></span>
                                                <span class="tree-icon" style="background:rgba(0,230,118,.06)"><i class="bi bi-router" style="color:var(--accent-green);font-size:11px"></i></span>
                                                <span class="tree-label">@(ont.Nom??ont.SerialNumber)</span>
                                                <span class="lbadge lvl-ont ms-2">ONT</span>
                                                <span class="si @oSi ms-2"></span>
                                              </div>
                                            }
                                          }
                                        </div></div>
                                      </div>
                                    }
                                  </div></div>
                                </div>
                              }
                            </div></div>
                          </div>
                        }
                      </div></div>
                    </div>
                  }
                </div></div>
              </div>
            }
          </div></div>
        </div>
      }
    </div>
  </div>
  <div class="col-xl-4">
    <div class="sg-card" style="position:sticky;top:72px">
      <div style="font-size:13px;font-weight:600;margin-bottom:16px">Légende</div>
      @foreach(var (label, cls, icon, color) in new[]{("Client","lvl-client","bi-building","#a78bff"),("Projet","lvl-projet","bi-folder2-open","var(--accent-cyan)"),("Zone","lvl-zone","bi-geo-alt","var(--accent-green)"),("OLT","lvl-olt","bi-server","var(--accent-amber)"),("FDT","lvl-fdt","bi-box","var(--text-secondary)"),("FAT","lvl-fat","bi-hdd-network","var(--accent-red)"),("ONT","lvl-ont","bi-router","var(--accent-green)")}){
        <div class="d-flex align-items-center gap-2 mb-2">
          <span class="lbadge @cls">@label</span>
          <i class="bi @icon" style="color:@color;font-size:13px"></i>
        </div>
      }
      <hr style="border-color:var(--border-subtle);margin:12px 0"/>
      <div style="font-size:11px;font-weight:600;color:var(--text-muted);margin-bottom:8px;font-family:var(--font-mono);text-transform:uppercase;letter-spacing:.08em">Statut ONT</div>
      <div class="d-flex gap-3 flex-wrap">
        <div class="d-flex align-items-center gap-2"><span class="si si-on"></span><span style="font-size:11.5px;color:var(--text-muted)">Actif</span></div>
        <div class="d-flex align-items-center gap-2"><span class="si si-warn"></span><span style="font-size:11.5px;color:var(--text-muted)">Alerte</span></div>
        <div class="d-flex align-items-center gap-2"><span class="si si-err"></span><span style="font-size:11.5px;color:var(--text-muted)">En panne</span></div>
      </div>
    </div>
  </div>
</div></div>
@section Scripts {
<script>
function expandAll(){
  document.querySelectorAll('#tree-panel .tree-children').forEach(c=>c.classList.add('open'));
  document.querySelectorAll('#tree-panel .tree-toggle').forEach(b=>{b.classList.add('open');const i=b.querySelector('i');if(i)i.className='bi bi-dash';});
}
function collapseAll(){
  document.querySelectorAll('#tree-panel .tree-children').forEach(c=>c.classList.remove('open'));
  document.querySelectorAll('#tree-panel .tree-toggle').forEach(b=>{b.classList.remove('open');const i=b.querySelector('i');if(i)i.className='bi bi-plus';});
}
</script>
}
