@model DashboardViewModel
@{ ViewData["Title"] = "Tableau de bord"; }

<div class="page-header">
  <h1 class="page-title"><i class="bi bi-speedometer2 me-2"></i>Tableau de bord</h1>
</div>

<div class="row g-3 mb-4">
  <div class="col-6 col-lg-3">
    <div class="stat-card">
      <div class="stat-icon text-primary"><i class="bi bi-building"></i></div>
      <div class="stat-value">@Model.TotalClients</div>
      <div class="stat-label">Clients</div>
    </div>
  </div>
  <div class="col-6 col-lg-3">
    <div class="stat-card">
      <div class="stat-icon text-success"><i class="bi bi-folder2-open"></i></div>
      <div class="stat-value">@Model.TotalProjets</div>
      <div class="stat-label">Projets</div>
    </div>
  </div>
  <div class="col-6 col-lg-3">
    <div class="stat-card">
      <div class="stat-icon text-warning"><i class="bi bi-geo-alt"></i></div>
      <div class="stat-value">@Model.TotalZones</div>
      <div class="stat-label">Zones</div>
    </div>
  </div>
  <div class="col-6 col-lg-3">
    <div class="stat-card">
      <div class="stat-icon text-info"><i class="bi bi-hdd-network"></i></div>
      <div class="stat-value">@Model.TotalOlts</div>
      <div class="stat-label">OLTs</div>
    </div>
  </div>
  <div class="col-6 col-lg-3">
    <div class="stat-card">
      <div class="stat-icon text-danger"><i class="bi bi-diagram-2"></i></div>
      <div class="stat-value">@Model.TotalFdts</div>
      <div class="stat-label">FDTs</div>
    </div>
  </div>
  <div class="col-6 col-lg-3">
    <div class="stat-card">
      <div class="stat-icon text-secondary"><i class="bi bi-share"></i></div>
      <div class="stat-value">@Model.TotalSplitters</div>
      <div class="stat-label">Splitters</div>
    </div>
  </div>
  <div class="col-6 col-lg-3">
    <div class="stat-card">
      <div class="stat-icon text-primary"><i class="bi bi-box"></i></div>
      <div class="stat-value">@Model.TotalFats</div>
      <div class="stat-label">FATs</div>
    </div>
  </div>
  <div class="col-6 col-lg-3">
    <div class="stat-card">
      <div class="stat-icon text-success"><i class="bi bi-boxes"></i></div>
      <div class="stat-value">@Model.TotalBpis</div>
      <div class="stat-label">BPIs</div>
    </div>
  </div>
  <div class="col-6 col-lg-3">
    <div class="stat-card">
      <div class="stat-icon text-warning"><i class="bi bi-arrow-left-right"></i></div>
      <div class="stat-value">@Model.TotalFibres</div>
      <div class="stat-label">Fibres</div>
    </div>
  </div>
  <div class="col-6 col-lg-3">
    <div class="stat-card">
      <div class="stat-icon text-info"><i class="bi bi-circle"></i></div>
      <div class="stat-value">@Model.TotalChambres</div>
      <div class="stat-label">Chambres</div>
    </div>
  </div>
</div>

<div class="row g-3">
  <div class="col-md-6">
    <div class="card shadow-sm">
      <div class="card-header fw-bold"><i class="bi bi-folder2 me-2"></i>Accès rapide</div>
      <div class="card-body d-flex flex-wrap gap-2">
        <a asp-controller="Projets" asp-action="Index" class="btn btn-outline-primary btn-sm">
          <i class="bi bi-folder2-open me-1"></i>Projets
        </a>
        <a asp-controller="Zones" asp-action="Index" class="btn btn-outline-info btn-sm">
          <i class="bi bi-geo-alt me-1"></i>Zones
        </a>
        <a asp-controller="Olts" asp-action="Index" class="btn btn-outline-secondary btn-sm">
          <i class="bi bi-hdd-network me-1"></i>OLTs
        </a>
        <a asp-controller="Fdts" asp-action="Index" class="btn btn-outline-warning btn-sm">
          <i class="bi bi-diagram-2 me-1"></i>FDTs
        </a>
        <a asp-controller="Security" asp-action="Index" class="btn btn-outline-danger btn-sm">
          <i class="bi bi-shield-check me-1"></i>Sécurité
        </a>
      </div>
    </div>
  </div>
  <div class="col-md-6">
    <div class="card shadow-sm">
      <div class="card-header fw-bold"><i class="bi bi-diagram-3 me-2"></i>Topologie GPON</div>
      <div class="card-body">
        <p class="text-muted mb-2" style="font-size:13px">Zone → OLT → FDT → Splitter (1x8 / 1x64) → FAT / BPI</p>
        <a asp-controller="Home" asp-action="ArchitectureGpon" class="btn btn-primary btn-sm">
          <i class="bi bi-diagram-3 me-1"></i>Voir l'architecture
        </a>
      </div>
    </div>
  </div>
</div>
