@model SmartGPON.Web.ViewModels.ClientUpdateVM
@{ ViewData["Title"] = "Modifier client"; }

<link rel="stylesheet" href="~/css/gpon-modal.css" />

<div class="gpon-overlay">
  <div class="gpon-modal">
    <div class="gpon-modal-header">
      <h5><i class="bi bi-pencil me-2"></i>Modifier client</h5>
      <a href="@Url.Action("Index")" class="btn-close-modal">✕</a>
    </div>
    <div class="gpon-modal-body">
      <form asp-action="Edit" method="post">
        @Html.AntiForgeryToken()
        <input asp-for="Id" type="hidden" />
        <div class="row g-3">
          <div class="col-md-8">
            <label asp-for="Nom" class="form-label text-muted small mb-1">Nom <span class="text-danger">*</span></label>
            <input asp-for="Nom" class="form-control" placeholder="Ex: Telecom Algérie">
            <span asp-validation-for="Nom" class="text-danger small"></span>
          </div>
          <div class="col-md-4">
            <label asp-for="Code" class="form-label text-muted small mb-1">Code <span class="text-danger">*</span></label>
            <input asp-for="Code" class="form-control" placeholder="Ex: TA-01">
            <span asp-validation-for="Code" class="text-danger small"></span>
          </div>
          <div class="col-12">
            <div class="form-check form-switch mt-1">
              <input asp-for="IsActive" class="form-check-input" type="checkbox">
              <label asp-for="IsActive" class="form-check-label">Client actif</label>
            </div>
          </div>
        </div>
        <div class="gpon-modal-footer">
          <a href="@Url.Action("Index")" class="btn-cancel">Annuler</a>
          <button type="submit" class="btn sg-btn sg-btn-primary">
            <i class="bi bi-check2 me-1"></i>Enregistrer
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

@section Scripts {
  @if (!ViewData.ModelState.IsValid) {
    <script>document.querySelector('.gpon-modal')?.scrollIntoView({behavior:'smooth'});</script>
  }
}
