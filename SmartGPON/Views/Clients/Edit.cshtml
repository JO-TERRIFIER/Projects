@* Views/Clients/Edit.cshtml *@
@model SmartGPON.Core.Entities.Client
@{ ViewData["Title"] = "Modifier client"; }

<div class="page-header">
    <div>
        <h1 class="page-title"><i class="bi bi-building me-2"></i>@ViewData["Title"]</h1>
        <div class="page-subtitle">Modifier les informations du client</div>
    </div>
    <a asp-action="Index" class="btn-ghost-sg"><i class="bi bi-arrow-left me-1"></i>Retour</a>
</div>

<div class="page-body">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="sg-card">
                <form asp-action="Edit" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />
                    <div class="row g-3">
                        <div class="col-md-8">
                            <label class="sg-label">Nom *</label>
                            <input asp-for="Nom" class="sg-input" required />
                            <span asp-validation-for="Nom" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label class="sg-label">Code *</label>
                            <input asp-for="Code" class="sg-input" required />
                            <span asp-validation-for="Code" class="text-danger small"></span>
                        </div>
                        <div class="col-12">
                            <label class="sg-label">Adresse</label>
                            <input asp-for="Adresse" class="sg-input" />
                        </div>
                        <div class="col-md-6">
                            <label class="sg-label">Email</label>
                            <input asp-for="Email" type="email" class="sg-input" />
                        </div>
                        <div class="col-md-6">
                            <label class="sg-label">TÃ©lÃ©phone</label>
                            <input asp-for="Telephone" class="sg-input" />
                        </div>
                        <div class="col-12">
                            <div class="form-check mt-1">
                                <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                                <label class="form-check-label" style="color:var(--text-secondary)">Actif</label>
                            </div>
                        </div>
                    </div>
                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn-primary-sg"><i class="bi bi-check-lg me-1"></i>Enregistrer</button>
                        <a asp-action="Index" class="btn-ghost-sg">Annuler</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
