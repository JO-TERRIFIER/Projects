@* Views/Clients/Index.cshtml *@
@model IEnumerable<SmartGPON.Core.Entities.Client>
@{ ViewData["Title"] = "Clients"; }

<div class="page-header">
    <div>
        <h1 class="page-title"><i class="bi bi-building me-2"></i>Clients</h1>
        <div class="page-subtitle">Gestion des clients GPON</div>
    </div>
    <a asp-action="Create" class="btn-primary-sg"><i class="bi bi-plus-lg me-1"></i>Nouveau client</a>
</div>

<div class="page-body">
    <div class="sg-card">
        <table class="sg-table">
            <thead><tr><th>Code</th><th>Nom</th><th>Email</th><th>Téléphone</th><th>Statut</th><th>Actions</th></tr></thead>
            <tbody>
            @foreach (var c in Model)
            {
                <tr>
                    <td><span class="mono text-accent fw-bold">@c.Code</span></td>
                    <td class="fw-semibold">@c.Nom</td>
                    <td><small class="mono" style="color:var(--text-muted)">@c.Email</small></td>
                    <td><small style="color:var(--text-muted)">@c.Telephone</small></td>
                    <td><span class="pill @(c.IsActive?"pill-green":"pill-red")">@(c.IsActive?"Actif":"Inactif")</span></td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@c.Id" class="icon-btn edit" title="Modifier"><i class="bi bi-pencil"></i></a>
                        <form asp-action="Delete" asp-route-id="@c.Id" method="post" class="d-inline" onsubmit="return confirm('Supprimer ce client ?')">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="icon-btn danger" title="Supprimer"><i class="bi bi-trash"></i></button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
