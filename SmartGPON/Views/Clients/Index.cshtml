@model List<ClientDisplayVM>
@{ ViewData["Title"] = "Clients"; }
<div class="page-header d-flex justify-content-between align-items-center">
  <h1 class="page-title"><i class="bi bi-building me-2"></i>Clients</h1>
  @if (!User.IsInRole("Visiteur")) {
    <a asp-action="Create" class="btn btn-primary btn-sm"><i class="bi bi-plus-lg me-1"></i>Nouveau client</a>
  }
</div>
@if (!Model.Any()) {
  <div class="alert alert-info">Aucun client.</div>
} else {
  <div class="card shadow-sm">
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead class="table-light"><tr>
          <th>Nom</th><th>Code</th><th>Actif</th><th class="text-end">Actions</th>
        </tr></thead>
        <tbody>
          @foreach (var c in Model) {
          <tr>
            <td class="fw-semibold">@c.Nom</td>
            <td><code>@c.Code</code></td>
            <td>@(c.IsActive ? "<span class=\"badge bg-success\">Actif</span>" : "<span class=\"badge bg-secondary\">Inactif</span>")</td>
            <td class="text-end">
              @if (!User.IsInRole("Visiteur")) {
                <a asp-action="Edit" asp-route-id="@c.Id" class="btn btn-sm btn-outline-secondary me-1"><i class="bi bi-pencil"></i></a>
                <form asp-action="Delete" asp-route-id="@c.Id" method="post" class="d-inline">
                  @Html.AntiForgeryToken()
                  <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                </form>
              }
            </td>
          </tr>
          }
        </tbody>
      </table>
    </div>
  </div>
}
