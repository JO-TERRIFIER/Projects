@model SmartGPON.Core.Entities.Zone
@{ 
    ViewData["Title"] = "Nouvelle zone"; 
    var isSuperviseur = User.IsInRole("Superviseur"); 
    var isChefProjet = User.IsInRole("ChefProjet") && !isSuperviseur; 
    var isTechDessin = User.IsInRole("TechDessin") && !isSuperviseur && !isChefProjet; 
    var canWrite = isSuperviseur || isChefProjet; 
    var canUpload = canWrite || isTechDessin; 
}
<div class="page-header"><div><h1 class="page-title">@ViewData["Title"]</h1></div><a asp-action="Index" class="btn-ghost-sg"><i class="bi bi-arrow-left"></i> Retour</a></div>
<div class="page-body">
  <form asp-action="Create" method="post" enctype="multipart/form-data">
    @Html.AntiForgeryToken()
    <div class="row g-4">
      <div class="col-lg-6">
        <div class="form-section"><div class="form-section-header"><div class="sec-icon" style="background:rgba(0,230,118,.1)"><i class="bi bi-geo-alt" style="color:var(--accent-green)"></i></div><span style="font-size:13px;font-weight:600">Zone gÃ©ographique</span></div>
        <div class="form-section-body"><div class="row g-3">
          <div class="col-12"><label class="sg-label">Nom *</label><input asp-for="Nom" class="sg-input form-control" required/></div>
          <div class="col-12"><label class="sg-label">Projet *</label>
            <select asp-for="ProjetId" class="sg-input form-select" required>
              <option value="">-- SÃ©lectionner --</option>
              @foreach(var p in ViewBag.Projets as List<SmartGPON.Core.Entities.Projet>??new()){<option value="@p.Id">@p.Nom</option>}
            </select></div>
          <div class="col-md-6"><label class="sg-label">Latitude</label><input asp-for="Latitude" class="sg-input form-control" type="number" step="0.0000001"/></div>
          <div class="col-md-6"><label class="sg-label">Longitude</label><input asp-for="Longitude" class="sg-input form-control" type="number" step="0.0000001"/></div>
          <div class="col-12"><label class="sg-label">Description</label><textarea asp-for="Description" class="sg-input form-control" rows="2"></textarea></div>
        </div></div></div>
      </div>
      @if(canUpload) {
      <div class="col-lg-6">
        <div class="form-section">
          <div class="form-section-header">
            <div class="sec-icon" style="background:rgba(255,179,0,.1)"><i class="bi bi-folder2" style="color:var(--accent-amber)"></i></div>
            <span style="font-size:13px;font-weight:600">Fichiers initiaux</span>
            <span class="pill pill-violet ms-2" style="font-size:9px">@(isTechDessin?".dwg":".dwg .pdf .png .jpg .xlsx")</span>
          </div>
          <div class="form-section-body">
             <label class="sg-label">Ajouter des fichiers Ã  la zone</label>
             <input type="file" name="uploadedFiles" class="sg-input form-control" accept="@(isTechDessin?".dwg":".dwg,.pdf,.png,.jpg,.jpeg,.xlsx")" multiple />
          </div>
        </div>
      </div>
      }
      <div class="col-12 mt-2">
        <div class="d-flex gap-2"><button type="submit" class="btn-primary-sg"><i class="bi bi-check-lg"></i> Enregistrer</button><a asp-action="Index" class="btn-ghost-sg">Annuler</a></div>
      </div>
    </div>
  </form>
</div>
