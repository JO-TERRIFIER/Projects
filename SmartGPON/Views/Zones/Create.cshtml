@model ZoneCreateVM
@{ ViewData["Title"] = "Nouvelle zone"; }
<div class="page-header"><h1 class="page-title"><i class="bi bi-geo-alt-fill me-2"></i>Nouvelle zone</h1></div>
<div class="card shadow-sm" style="max-width:600px">
  <div class="card-body">
    <form asp-action="Create" method="post">
      @Html.AntiForgeryToken()
      <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
      <div class="mb-3">
        <label asp-for="Nom" class="form-label fw-semibold">Nom</label>
        <input asp-for="Nom" class="form-control" placeholder="Ex: Zone Nord" />
        <span asp-validation-for="Nom" class="text-danger small"></span>
      </div>
      <div class="mb-3">
        <label asp-for="ProjetId" class="form-label fw-semibold">Projet</label>
        <select asp-for="ProjetId" class="form-select" asp-items="ViewBag.ProjetsSelectList">
          <option value="">— Choisir un projet —</option>
        </select>
        <span asp-validation-for="ProjetId" class="text-danger small"></span>
      </div>
      <div class="row mb-3">
        <div class="col">
          <label asp-for="Latitude" class="form-label fw-semibold">Latitude</label>
          <input asp-for="Latitude" class="form-control" placeholder="Ex: 33.8869" />
        </div>
        <div class="col">
          <label asp-for="Longitude" class="form-label fw-semibold">Longitude</label>
          <input asp-for="Longitude" class="form-control" placeholder="Ex: 9.5375" />
        </div>
      </div>
      <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>Créer</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Annuler</a>
      </div>
    </form>
  </div>
</div>
