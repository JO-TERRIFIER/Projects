@model List<SmartGPON.Web.ViewModels.ZoneDisplayVM>
@{ ViewData["Title"] = "Zones"; }

<div class="page-header">
  <div class="d-flex align-items-center justify-content-between mb-4">
    <div>
      <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-1">
          <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Accueil</a></li>
          <li class="breadcrumb-item active">Zones</li>
        </ol>
      </nav>
      <h1 class="h4 mb-0 fw-500"><i class="bi bi-geo-alt me-2"></i>Zones</h1>
    </div>
    @if (!User.IsInRole("Visiteur"))
    {
      <a asp-action="Create" class="btn sg-btn sg-btn-primary">
        <i class="bi bi-plus me-1"></i>Nouvelle zone
      </a>
    }
  </div>
</div>

<div class="page-body">
  <div class="sg-card">
    <div class="d-flex gap-2 mb-3">
      <input type="search" id="srch" class="form-control form-control-sm" placeholder="Rechercher une zone…">
    </div>
    <table class="sg-table" id="tbl">
      <thead>
        <tr>
          <th>Zone</th>
          <th>Projet</th>
          <th>Coordonnées</th>
          <th>OLTs</th>
          <th>Documents</th>
          <th style="width:120px">Actions</th>
        </tr>
      </thead>
      <tbody>
        @foreach (var item in Model)
        {
          <tr data-search="@item.Nom @item.ProjetNom">
            <td class="fw-500">@item.Nom</td>
            <td class="text-muted">@item.ProjetNom</td>
            <td class="text-muted" style="font-size:12px">
              @if (item.Latitude.HasValue && item.Longitude.HasValue)
              { @($"{item.Latitude:F4}, {item.Longitude:F4}") }
              else
              { <span>—</span> }
            </td>
            <td>@item.OltCount OLT(s)</td>
            <td>
              <button class="sg-upload-btn" onclick="openDocPopup(@item.ProjetId, @item.Id, '@Html.Raw(Html.Encode(item.Nom))', sgUrls)">
                <i class="bi bi-folder me-1"></i>Voir
              </button>
            </td>
            <td>
              <div class="d-flex gap-1">
                <a asp-controller="Olts" asp-action="Index" asp-route-zoneId="@item.Id"
                   class="btn sg-btn sg-btn-outline btn-sm" title="Voir OLTs">
                  <i class="bi bi-hdd-network"></i>
                </a>
                @if (!User.IsInRole("Visiteur"))
                {
                  <a asp-action="Edit" asp-route-id="@item.Id"
                     class="btn sg-btn sg-btn-outline btn-sm">
                    <i class="bi bi-pencil"></i>
                  </a>
                  <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn sg-btn sg-btn-danger btn-sm">
                      <i class="bi bi-trash"></i>
                    </button>
                  </form>
                }
              </div>
            </td>
          </tr>
        }
      </tbody>
    </table>
  </div>
</div>

@section Scripts {
<script src="~/js/gpon-fileui.js"></script>
<script>
const srch = document.getElementById('srch');
srch.addEventListener('input', () => {
  const s = srch.value.toLowerCase();
  document.querySelectorAll('#tbl tbody tr').forEach(r => {
    r.style.display = !s || r.dataset.search?.toLowerCase().includes(s) ? '' : 'none';
  });
});

const sgUrls = {
  getFiles:     '@Url.Action("GetFiles","Resources")',
  downloadBase: '@Url.Action("Download","Resources")'
};

// A3 guard confirmed: Delete cascade Zone
document.querySelectorAll('form[DELETEGUARD]').forEach(form => {
  form.addEventListener('submit', async function(e) {
    e.preventDefault();
    const fd = new FormData(this);
    const res = await fetch(this.action, { method: 'POST', body: fd,
      headers: { 'X-Requested-With': 'XMLHttpRequest' } });
    const json = await res.json().catch(() => null);
    if (json?.needsConfirmation) {
      if (!confirm(`Cette zone contient ${json.count} fichier(s). Supprimer quand même ?`)) return;
      fd.append('confirmed', 'true');
      await fetch(this.action, { method: 'POST', body: fd });
    }
    window.location.href = '@Url.Action("Index")';
  });
});
</script>
}
