@* Views/Zones/Index.cshtml *@
@model IEnumerable<SmartGPON.Core.Entities.Zone>
@{ ViewData["Title"] = "Zones"; }
<div class="page-header"><div><h1 class="page-title">Zones</h1><div class="page-subtitle">Zones géographiques de déploiement</div></div><a asp-action="Create" class="btn-primary-sg"><i class="bi bi-plus-lg"></i> Nouvelle zone</a></div>
<div class="page-body"><div class="sg-card p-0" style="overflow:hidden"><div style="overflow-x:auto"><table class="sg-table">
  <thead><tr><th style="padding-left:20px">Nom</th><th>Projet</th><th>Latitude</th><th>Longitude</th><th style="padding-right:20px;text-align:right">Actions</th></tr></thead>
  <tbody>
  @foreach(var z in Model){<tr>
    <td style="padding-left:20px;font-weight:500;color:var(--text-primary)">@z.Nom</td>
    <td><span class="pill pill-cyan" style="font-size:10px">@z.Projet?.Nom</span></td>
    <td class="mono" style="font-size:11.5px;color:var(--text-muted)">@z.Latitude?.ToString("F4")</td>
    <td class="mono" style="font-size:11.5px;color:var(--text-muted)">@z.Longitude?.ToString("F4")</td>
    <td style="padding-right:20px;text-align:right"><div class="d-flex justify-content-end gap-1">
      <a asp-action="Edit" asp-route-id="@z.Id" class="icon-btn edit"><i class="bi bi-pencil"></i></a>
      <form asp-action="Delete" asp-route-id="@z.Id" method="post" class="d-inline" onsubmit="return confirm('Supprimer ?')">@Html.AntiForgeryToken()<button type="submit" class="icon-btn danger"><i class="bi bi-trash3"></i></button></form>
    </div></td>
  </tr>}
  </tbody>
</table></div></div></div>
