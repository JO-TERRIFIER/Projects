@* Views/Zones/Index.cshtml *@
@model IEnumerable<SmartGPON.Core.Entities.Zone>
@{
  ViewData["Title"] = "Zones";
  var isSuperviseur = User.IsInRole("Superviseur");
  var isChefProjet = User.IsInRole("ChefProjet") && !isSuperviseur;
  var canWrite = isSuperviseur || isChefProjet;
}
<div class="page-header"><div><h1 class="page-title">Zones</h1><div class="page-subtitle">Zones géographiques de déploiement</div></div>
  @if (canWrite)
  {
    <a asp-action="Create" class="btn-primary-sg"><i class="bi bi-plus-lg"></i> Nouvelle zone</a>
  }
</div>
<div class="page-body"><div class="sg-card p-0" style="overflow:hidden"><div style="overflow-x:auto"><table class="sg-table">
  <thead><tr><th style="padding-left:20px">Nom</th><th>Projet</th><th>Latitude</th><th>Longitude</th><th>Documents</th><th style="padding-right:20px;text-align:right">Actions</th></tr></thead>
  <tbody>
  @foreach (var z in Model)
  {
    var resCount = z.Resources?.Count ?? 0;
    var isTechDessin = User.IsInRole("TechDessin") && !isSuperviseur && !isChefProjet;
    var canUpload = canWrite || isTechDessin;
    <tr>
      <td style="padding-left:20px;font-weight:500;color:var(--text-primary)">@z.Nom</td>
      <td><span class="pill pill-cyan" style="font-size:10px">@z.Projet?.Nom</span></td>
      <td class="mono" style="font-size:11.5px;color:var(--text-muted)">@z.Latitude?.ToString("F4")</td>
      <td class="mono" style="font-size:11.5px;color:var(--text-muted)">@z.Longitude?.ToString("F4")</td>
      <td>
        <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#docsModal-z-@z.Id" style="font-size:11px;padding:3px 8px;border-radius:12px;display:flex;align-items:center;gap:4px">
            <i class="bi bi-folder2-open"></i> @resCount doc@(resCount > 1 ? "s" : "")
        </button>
        <div class="modal fade" id="docsModal-z-@z.Id" tabindex="-1" aria-hidden="true">
          <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content" style="border:none;border-radius:12px;box-shadow:0 8px 30px rgba(0,0,0,0.12)">
              <div class="modal-header" style="border-bottom:1px solid var(--border-subtle);background:#fbfbfb;border-top-left-radius:12px;border-top-right-radius:12px">
                <h5 class="modal-title" style="font-size:14px;font-weight:600"><i class="bi bi-folder2-open me-2" style="color:var(--accent-amber)"></i>Documents de la zone : @z.Nom</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
              </div>
              <div class="modal-body p-4 text-start">
                @if (canUpload) {
                  <form asp-controller="Resources" asp-action="Upload" method="post" enctype="multipart/form-data" class="mb-4 p-3" style="background:var(--bg-subtle);border-radius:8px">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="zoneId" value="@z.Id"/>
                    <div style="font-size:12px;font-weight:600;margin-bottom:8px">Nouveau fichier <span class="pill pill-violet ms-2" style="font-size:9px">@(isTechDessin?".dwg":".dwg .pdf .png .jpg .xlsx")</span></div>
                    <div class="d-flex gap-2">
                      <input type="file" name="file" class="sg-input form-control form-control-sm" accept="@(isTechDessin?".dwg":".dwg,.pdf,.png,.jpg,.jpeg,.xlsx")" required style="flex:1" />
                      <input type="text" name="uploadDescription" class="sg-input form-control form-control-sm" placeholder="Description" required style="width:200px" />
                      <button type="submit" class="btn-primary-sg px-3 py-1 m-0" style="height:auto"><i class="bi bi-upload"></i> Ajouter</button>
                    </div>
                  </form>
                }
                @if(resCount == 0) {
                  <div style="color:var(--text-muted);font-size:12px;text-align:center;padding:16px"><i class="bi bi-inbox d-block mb-2 fs-4"></i>Aucun fichier</div>
                } else {
                  <div style="max-height:300px;overflow-y:auto;border:1px solid var(--border-subtle);border-radius:8px">
                    @foreach(var r in (z.Resources ?? new List<SmartGPON.Core.Entities.Resource>()).OrderByDescending(x => x.DateUpload)) {
                      var icon = r.TypeFichier switch { ".pdf"=>"bi-filetype-pdf", ".dwg"=>"bi-vector-pen", ".xlsx"=>"bi-file-earmark-spreadsheet", ".png" or ".jpg" or ".jpeg"=>"bi-image", _=>"bi-file-earmark" };
                      var color = r.TypeFichier switch { ".pdf"=>"var(--accent-red)", ".dwg"=>"var(--accent-green)", ".xlsx"=>"var(--accent-green)", _=>"var(--accent-cyan)" };
                      <div class="d-flex align-items-center gap-3 p-3" style="border-bottom:1px solid var(--border-subtle)">
                        <i class="bi @icon" style="color:@color;font-size:20px"></i>
                        <div style="flex:1;min-width:0">
                          <div style="font-size:13px;font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">@r.NomFichier</div>
                          <div style="font-size:11px;color:var(--text-muted)">@(r.TailleFichier/1024) Ko — @r.DateUpload.ToString("dd/MM/yyyy HH:mm")</div>
                        </div>
                        <a asp-controller="Resources" asp-action="Download" asp-route-id="@r.Id" class="btn btn-sm btn-outline-primary py-1 px-2" style="font-size:11px"><i class="bi bi-download"></i> Tél.</a>
                        @if (isSuperviseur) {
                          <form asp-controller="Resources" asp-action="Delete" asp-route-id="@r.Id" method="post" class="d-inline" onsubmit="return confirm('Confirmer la suppression automatique ?')">@Html.AntiForgeryToken()<button type="submit" class="btn btn-sm btn-outline-danger py-1 px-2" style="font-size:11px" title="Supprimer"><i class="bi bi-trash3"></i></button></form>
                        } else if (isChefProjet || isTechDessin) {
                          <form asp-controller="Resources" asp-action="Delete" asp-route-id="@r.Id" method="post" class="d-inline" onsubmit="return confirm('Demander la suppression de ce fichier ?')">@Html.AntiForgeryToken()<button type="submit" class="btn btn-sm btn-outline-warning py-1 px-2" style="font-size:11px" title="Demander suppression"><i class="bi bi-trash3"></i></button></form>
                        }
                      </div>
                    }
                  </div>
                }
              </div>
            </div>
          </div>
        </div>
      </td>
      <td style="padding-right:20px;text-align:right"><div class="d-flex justify-content-end gap-1">
        @if (isSuperviseur)
        {
          <a asp-action="Edit" asp-route-id="@z.Id" class="icon-btn edit" title="Modifier"><i class="bi bi-pencil"></i></a>
          <form asp-action="Delete" asp-route-id="@z.Id" method="post" class="d-inline" onsubmit="return confirm('Supprimer ?')">
            @Html.AntiForgeryToken()
            <button type="submit" class="icon-btn danger" title="Supprimer"><i class="bi bi-trash3"></i></button>
          </form>
        }
        else if (isChefProjet)
        {
          <a asp-action="Edit" asp-route-id="@z.Id" class="icon-btn edit" title="Modifier"><i class="bi bi-pencil"></i></a>
          <form asp-action="Delete" asp-route-id="@z.Id" method="post" class="d-inline" onsubmit="return confirm('Demander la suppression de cette zone ?')">
            @Html.AntiForgeryToken()
            <button type="submit" class="icon-btn warning" title="Demander suppression" style="color:var(--color-status-warning)"><i class="bi bi-trash3"></i></button>
          </form>
        }
      </div></td>
    </tr>
  }
  </tbody>
</table></div></div></div>


