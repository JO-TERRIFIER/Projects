@model List<ZoneDisplayVM>
@{ ViewData["Title"] = "Zones"; }
<div class="page-header d-flex justify-content-between align-items-center">
  <h1 class="page-title"><i class="bi bi-geo-alt me-2"></i>Zones</h1>
  @if (!User.IsInRole("Visiteur")) {
    <a asp-action="Create" class="btn btn-primary btn-sm"><i class="bi bi-plus-lg me-1"></i>Nouvelle zone</a>
  }
</div>
@if (!Model.Any()) {
  <div class="alert alert-info">Aucune zone accessible.</div>
} else {
  <div class="card shadow-sm">
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead class="table-light"><tr>
          <th>Nom</th><th>Projet</th><th>Latitude</th><th>Longitude</th><th class="text-end">Actions</th>
        </tr></thead>
        <tbody>
          @foreach (var z in Model) {
          <tr>
            <td class="fw-semibold">@z.Nom</td>
            <td>@z.ProjetNom</td>
            <td>@(z.Latitude?.ToString("F6") ?? "—")</td>
            <td>@(z.Longitude?.ToString("F6") ?? "—")</td>
            <td class="text-end">
              <a asp-action="Details" asp-route-id="@z.Id" class="btn btn-sm btn-outline-info me-1"><i class="bi bi-eye"></i></a>
              @if (!User.IsInRole("Visiteur")) {
                <a asp-action="Edit" asp-route-id="@z.Id" class="btn btn-sm btn-outline-secondary me-1"><i class="bi bi-pencil"></i></a>
                <form asp-action="Delete" asp-route-id="@z.Id" method="post" class="d-inline">
                  @Html.AntiForgeryToken()
                  <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                </form>
              }
            </td>
          </tr>
          }
        </tbody>
      </table>
    </div>
  </div>
}
