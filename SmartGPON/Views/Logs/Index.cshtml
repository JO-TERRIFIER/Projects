  <button class="btn-ghost-sg" onclick="window.print()"><i class="bi bi-download"></i> Export</button>
</div>
<div class="page-body">
  <div class="sg-card p-0" style="overflow:hidden"><div style="overflow-x:auto"><table class="sg-table" style="font-size:12.5px">
