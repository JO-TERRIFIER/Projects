@model IEnumerable<SmartGPON.Core.Entities.Fdt>
@{
  ViewData["Title"] = "FDTs";
  var isSuperviseurOrChef = User.IsInRole("Superviseur") || User.IsInRole("ChefProjet");
  var isTechTerrain = User.IsInRole("TechTerrain") && !isSuperviseurOrChef;
  var canWrite = isSuperviseurOrChef || isTechTerrain;
}
<div class="page-header"><div><h1 class="page-title">FDTs</h1><div class="page-subtitle">Fibre Distribution Terminals — configuration splitters 1:8 (immeubles) et 1:64 (villas)</div></div>
  @if (canWrite)
  {
    <a asp-action="Create" class="btn-primary-sg"><i class="bi bi-plus-lg"></i> Nouveau FDT</a>
  }
</div>
<div class="page-body"><div class="sg-card p-0" style="overflow:hidden"><div style="overflow-x:auto"><table class="sg-table">
  <thead><tr><th style="padding-left:20px">Nom</th><th>OLT</th><th>Capacité</th><th>Splitters 1:8</th><th>Splitters 1:64</th><th>Coordonnées</th><th>Statut</th><th style="padding-right:20px;text-align:right">Actions</th></tr></thead>
  <tbody>
  @foreach(var f in Model){
    var pill = f.Statut==SmartGPON.Core.Enums.StatutEquipement.Actif?"pill-green":f.Statut==SmartGPON.Core.Enums.StatutEquipement.EnPanne?"pill-red":"pill-amber";
    <tr><td style="padding-left:20px;font-weight:500;color:var(--text-primary)" class="mono">@f.Nom</td>
    <td style="font-size:12px;color:var(--text-muted)">@f.Olt?.Nom</td>
    <td class="mono" style="color:var(--accent-cyan)">@f.Capacite</td>
    <td class="mono" style="color:var(--accent-amber)">@f.NbSplitters1x8</td>
    <td class="mono" style="color:#a78bff">@f.NbSplitters1x64</td>
    <td class="mono" style="font-size:11px;color:var(--text-muted)">@(f.Latitude.HasValue ? $"{f.Latitude:F4}, {f.Longitude:F4}" : "—")</td>
    <td><span class="pill @pill">@f.Statut</span></td>
    <td style="padding-right:20px;text-align:right"><div class="d-flex justify-content-end gap-1">
      @if (isSuperviseurOrChef)
      {
        <a asp-action="Edit" asp-route-id="@f.Id" class="icon-btn edit" title="Modifier"><i class="bi bi-pencil"></i></a>
        <form asp-action="Delete" asp-route-id="@f.Id" method="post" class="d-inline" onsubmit="return confirm('Supprimer ?')">@Html.AntiForgeryToken()<button type="submit" class="icon-btn danger" title="Supprimer"><i class="bi bi-trash3"></i></button></form>
      }
      else if (isTechTerrain)
      {
        <a asp-action="Edit" asp-route-id="@f.Id" class="icon-btn edit" title="Demander modification"><i class="bi bi-pencil-square"></i></a>
        <form asp-action="Delete" asp-route-id="@f.Id" method="post" class="d-inline" onsubmit="return confirm('Demander la suppression de ce FDT ?')">@Html.AntiForgeryToken()<button type="submit" class="icon-btn warning" title="Demander suppression" style="color:var(--color-status-warning)"><i class="bi bi-trash3"></i></button></form>
      }
    </div></td></tr>
  }
  </tbody>
</table></div></div></div>


