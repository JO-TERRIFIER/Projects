@model FdtCreateVM
@{ ViewData["Title"] = "Nouveau FDT"; }
<div class="page-header"><h1 class="page-title"><i class="bi bi-diagram-2 me-2"></i>Nouveau FDT</h1></div>
<div class="card shadow-sm" style="max-width:600px">
  <div class="card-body">
    <form asp-action="Create" method="post">
      @Html.AntiForgeryToken()
      <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
      <div class="mb-3">
        <label asp-for="Nom" class="form-label fw-semibold">Nom</label>
        <input asp-for="Nom" class="form-control" placeholder="Ex: FDT-NORD-01" />
        <span asp-validation-for="Nom" class="text-danger small"></span>
      </div>
      <div class="mb-3">
        <label asp-for="OltId" class="form-label fw-semibold">OLT</label>
        <select asp-for="OltId" class="form-select" asp-items="ViewBag.OltsSelectList">
          <option value="">— Choisir un OLT —</option>
        </select>
        <span asp-validation-for="OltId" class="text-danger small"></span>
      </div>
      <div class="row mb-4">
        <div class="col">
          <label asp-for="Latitude" class="form-label fw-semibold">Latitude</label>
          <input asp-for="Latitude" class="form-control" placeholder="Ex: 33.8869" />
        </div>
        <div class="col">
          <label asp-for="Longitude" class="form-label fw-semibold">Longitude</label>
          <input asp-for="Longitude" class="form-control" placeholder="Ex: 9.5375" />
        </div>
      </div>
      <div class="alert alert-info" style="font-size:13px">
        <i class="bi bi-info-circle me-1"></i>Les Splitters sont gérés dans la fiche détail du FDT (1x8 Immeubles / 1x64 Villas).
      </div>
      <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>Créer</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Annuler</a>
      </div>
    </form>
  </div>
</div>
