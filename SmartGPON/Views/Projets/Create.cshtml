@model SmartGPON.Web.ViewModels.ProjetCreateVM
@using SmartGPON.Core.Enums
@{ ViewData["Title"] = "Nouveau projet"; }

<link rel="stylesheet" href="~/css/gpon-modal.css" />
<link rel="stylesheet" href="~/css/gpon-fileui.css" />

<div class="gpon-overlay">
  <div class="gpon-modal">
    <div class="gpon-modal-header">
      <h5><i class="bi bi-folder-plus me-2"></i>Nouveau projet</h5>
      <a href="@Url.Action("Index")" class="btn-close-modal">✕</a>
    </div>
    <div class="gpon-modal-body">
      <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="sessionGuid" value="@ViewBag.SessionGuid" />
        <div class="row g-3">
          <div class="col-md-8">
            <label asp-for="Nom" class="form-label text-muted small mb-1">Nom <span class="text-danger">*</span></label>
            <input asp-for="Nom" class="form-control" placeholder="Ex: Déploiement Fibre Z1">
            <span asp-validation-for="Nom" class="text-danger small"></span>
          </div>
          <div class="col-md-4">
            <label asp-for="Statut" class="form-label text-muted small mb-1">Statut</label>
            <select asp-for="Statut" class="form-select">
              <option value="@ProjetStatut.EnCours">En cours</option>
              <option value="@ProjetStatut.Termine">Terminé</option>
              <option value="@ProjetStatut.Suspendu">Suspendu</option>
            </select>
          </div>
          <div class="col-12">
            <label asp-for="ClientId" class="form-label text-muted small mb-1">Client <span class="text-danger">*</span></label>
            <select asp-for="ClientId" class="form-select">
              <option value="">— Sélectionner un client —</option>
              @if (ViewBag.Clients != null)
              {
                foreach (var c in (IEnumerable<SmartGPON.Core.Entities.Client>)ViewBag.Clients)
                {
                  <option value="@c.Id">@c.Nom (@c.Code)</option>
                }
              }
            </select>
            <span asp-validation-for="ClientId" class="text-danger small"></span>
          </div>

          @* ── Zone upload (masquée Visiteur/TechTerrain) ── *@
          @if (!User.IsInRole("Visiteur") && !User.IsInRole("TechTerrain"))
          {
            <div class="col-12">
              <label class="form-label text-muted small mb-1">
                <i class="bi bi-paperclip me-1"></i>Fichiers (optionnel)
              </label>
              <div id="create-file-zone"
                   data-upload-temp-url="@Url.Action("UploadTemp","Resources")"
                   data-delete-temp-url="@Url.Action("DeleteTemp","Resources")"
                   data-session-guid="@ViewBag.SessionGuid">
                <div class="sg-file-zone" tabindex="0" role="button"
                     aria-label="Zone de dépôt de fichiers">
                  <i class="bi bi-cloud-upload"></i>
                  Glisser-déposer ou cliquer pour ajouter des fichiers
                  <br><small class="text-muted">Max @ViewBag.MaxSizeMb MB · extensions autorisées</small>
                </div>
                <input type="file" class="d-none" multiple />
                <div class="sg-file-list mt-2"></div>
              </div>
            </div>
          }

        </div>
        <div class="gpon-modal-footer">
          <a href="@Url.Action("Index")" class="btn-cancel">Annuler</a>
          <button type="submit" class="btn sg-btn sg-btn-primary">
            <i class="bi bi-check2 me-1"></i>Enregistrer
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

@section Scripts {
  <script src="~/js/gpon-fileui.js"></script>
  <script>
    @if (!User.IsInRole("Visiteur") && !User.IsInRole("TechTerrain"))
    {
      <text>initFileZone('create-file-zone', 'temp');</text>
    }
    @if (!ViewData.ModelState.IsValid) {
      <text>document.querySelector('.gpon-modal')?.scrollIntoView({behavior:'smooth'});</text>
    }
  </script>
}
