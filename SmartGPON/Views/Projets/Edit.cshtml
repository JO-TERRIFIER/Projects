@model SmartGPON.Web.ViewModels.ProjetUpdateVM
@using SmartGPON.Core.Enums
@{ ViewData["Title"] = "Modifier projet"; }

<link rel="stylesheet" href="~/css/gpon-modal.css" />

<div class="gpon-overlay">
  <div class="gpon-modal">
    <div class="gpon-modal-header">
      <h5><i class="bi bi-pencil me-2"></i>Modifier projet</h5>
      <a href="@Url.Action("Index")" class="btn-close-modal">✕</a>
    </div>
    <div class="gpon-modal-body">
      <form asp-action="Edit" method="post">
        @Html.AntiForgeryToken()
        <input asp-for="Id" type="hidden" />
        <div class="row g-3">
          <div class="col-md-8">
            <label asp-for="Nom" class="form-label text-muted small mb-1">Nom <span class="text-danger">*</span></label>
            <input asp-for="Nom" class="form-control">
            <span asp-validation-for="Nom" class="text-danger small"></span>
          </div>
          <div class="col-md-4">
            <label asp-for="Statut" class="form-label text-muted small mb-1">Statut</label>
            <select asp-for="Statut" class="form-select">
              <option value="@ProjetStatut.EnCours">En cours</option>
              <option value="@ProjetStatut.Termine">Terminé</option>
              <option value="@ProjetStatut.Suspendu">Suspendu</option>
            </select>
          </div>
          <div class="col-12">
            <label asp-for="ClientId" class="form-label text-muted small mb-1">Client <span class="text-danger">*</span></label>
            <select asp-for="ClientId" class="form-select">
              <option value="">— Sélectionner un client —</option>
              @if (ViewBag.Clients != null)
              {
                foreach (var c in (IEnumerable<SmartGPON.Core.Entities.Client>)ViewBag.Clients)
                {
                  <option value="@c.Id">@c.Nom (@c.Code)</option>
                }
              }
            </select>
            <span asp-validation-for="ClientId" class="text-danger small"></span>
          </div>
        </div>
        <div class="gpon-modal-footer">
          <a href="@Url.Action("Index")" class="btn-cancel">Annuler</a>
          <button type="submit" class="btn sg-btn sg-btn-primary">
            <i class="bi bi-check2 me-1"></i>Enregistrer
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

@section Scripts {
  @if (!ViewData.ModelState.IsValid) {
    <script>document.querySelector('.gpon-modal')?.scrollIntoView({behavior:'smooth'});</script>
  }
}
