@model SmartGPON.Core.Entities.Projet
@{ ViewData["Title"] = (Model.Id == 0 ? "Nouveau" : "Modifier") + " projet"; }
<div class="page-header">
  <div><h1 class="page-title">@ViewData["Title"]</h1></div>
  <a asp-action="Index" class="btn-ghost-sg"><i class="bi bi-arrow-left"></i> Retour</a>
</div>
<div class="page-body">
  <div style="max-width:580px">
    <form asp-action="@(Model.Id==0?"Create":"Edit")" method="post">
      @Html.AntiForgeryToken()
      @if(Model.Id!=0){<input type="hidden" asp-for="Id"/>}
      <div class="form-section">
        <div class="form-section-header">
          <div class="sec-icon" style="background:rgba(0,200,224,.12)"><i class="bi bi-folder2-open" style="color:var(--accent-cyan)"></i></div>
          <span style="font-size:13px;font-weight:600">Informations projet</span>
        </div>
        <div class="form-section-body">
          <div class="row g-3">
            <div class="col-12">
              <label class="sg-label">Nom du projet *</label>
              <input asp-for="Nom" class="sg-input form-control" required/>
              <span asp-validation-for="Nom" class="text-danger fs-11"></span>
            </div>
            <div class="col-md-6">
              <label class="sg-label">Client *</label>
              <select asp-for="ClientId" class="sg-input form-select" required>
                <option value="">-- Sélectionner --</option>
                @foreach(var c in ViewBag.Clients as List<SmartGPON.Core.Entities.Client> ?? new())
                { <option value="@c.Id">@c.Nom</option> }
              </select>
            </div>
            <div class="col-md-6">
              <label class="sg-label">Statut</label>
              <select asp-for="Statut" asp-items="Html.GetEnumSelectList<SmartGPON.Core.Enums.ProjetStatut>()" class="sg-input form-select"></select>
            </div>
            <div class="col-md-6">
              <label class="sg-label">Date début</label>
              <input asp-for="DateDebut" type="date" class="sg-input form-control"/>
            </div>
            <div class="col-md-6">
              <label class="sg-label">Date fin prévue</label>
              <input asp-for="DateFin" type="date" class="sg-input form-control"/>
            </div>
            <div class="col-12">
              <label class="sg-label">Description</label>
              <textarea asp-for="Description" class="sg-input form-control" rows="3"></textarea>
            </div>
          </div>
        </div>
      </div>
      <div class="d-flex gap-2">
        <button type="submit" class="btn-primary-sg"><i class="bi bi-check-lg"></i> Enregistrer</button>
        <a asp-action="Index" class="btn-ghost-sg">Annuler</a>
      </div>
    </form>
  </div>
</div>
