@* =========================================================
   Views/Projets/Index.cshtml
   ========================================================= *@
@model IEnumerable<SmartGPON.Core.Entities.Projet>
@{ ViewData["Title"] = "Projets"; }
<div class="page-header">
  <div><h1 class="page-title">Gestion des projets</h1><div class="page-subtitle">Portefeuille opérationnel GPON</div></div>
  <a asp-action="Create" class="btn-primary-sg"><i class="bi bi-plus-lg"></i> Nouveau projet</a>
</div>
<div class="page-body">
  <div class="sg-card p-0" style="overflow:hidden">
    <div style="overflow-x:auto">
      <table class="sg-table">
        <thead><tr>
          <th style="padding-left:20px">Nom</th><th>Client</th><th>Statut</th>
          <th>Date début</th><th>Date fin</th><th style="padding-right:20px;text-align:right">Actions</th>
        </tr></thead>
        <tbody>
        @foreach (var p in Model)
        {
          var pill = p.Statut == SmartGPON.Core.Enums.ProjetStatut.Termine ? "pill-green"
                   : p.Statut == SmartGPON.Core.Enums.ProjetStatut.Suspendu ? "pill-amber" : "pill-cyan";
          var label = p.Statut == SmartGPON.Core.Enums.ProjetStatut.Termine ? "Terminé"
                    : p.Statut == SmartGPON.Core.Enums.ProjetStatut.Suspendu ? "Suspendu" : "Actif";
          <tr>
            <td style="padding-left:20px;font-weight:500;color:var(--text-primary)">@p.Nom</td>
            <td>@p.Client?.Nom</td>
            <td><span class="pill @pill">@label</span></td>
            <td class="mono" style="font-size:11.5px;color:var(--text-muted)">@p.DateDebut?.ToString("dd/MM/yyyy")</td>
            <td class="mono" style="font-size:11.5px;color:var(--text-muted)">@p.DateFin?.ToString("dd/MM/yyyy")</td>
            <td style="padding-right:20px;text-align:right">
              <div class="d-flex justify-content-end gap-1">
                <a asp-action="Edit" asp-route-id="@p.Id" class="icon-btn edit"><i class="bi bi-pencil"></i></a>
                <form asp-action="Delete" asp-route-id="@p.Id" method="post" class="d-inline" onsubmit="return confirm('Supprimer ce projet ?')">
                  @Html.AntiForgeryToken()
                  <button type="submit" class="icon-btn danger"><i class="bi bi-trash3"></i></button>
                </form>
              </div>
            </td>
          </tr>
        }
        </tbody>
      </table>
    </div>
  </div>
</div>
