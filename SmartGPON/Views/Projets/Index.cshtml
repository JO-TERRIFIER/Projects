@model List<SmartGPON.Web.ViewModels.ProjetDisplayVM>
@using SmartGPON.Core.Enums
@{ ViewData["Title"] = "Projets"; }

<link rel="stylesheet" href="~/css/gpon-fileui.css" />

<div class="page-header">
  <div class="d-flex align-items-center justify-content-between mb-4">
    <div>
      <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-1">
          <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Accueil</a></li>
          <li class="breadcrumb-item active">Projets</li>
        </ol>
      </nav>
      <h1 class="h4 mb-0 fw-500"><i class="bi bi-folder me-2"></i>Projets</h1>
    </div>
    @if (!User.IsInRole("Visiteur"))
    {
      <a asp-action="Create" class="btn sg-btn sg-btn-primary">
        <i class="bi bi-plus me-1"></i>Nouveau projet
      </a>
    }
  </div>
</div>

<div class="page-body">
  <div class="sg-card">
    <div class="d-flex gap-2 mb-3">
      <input type="search" id="srch" class="form-control form-control-sm" placeholder="Rechercher un projet…">
      <select id="filt" class="form-select form-select-sm" style="width:180px">
        <option value="">Tous les statuts</option>
        <option value="EnCours">En cours</option>
        <option value="Termine">Terminé</option>
        <option value="Suspendu">Suspendu</option>
      </select>
    </div>
    <table class="sg-table" id="tbl">
      <thead>
        <tr>
          <th>Projet</th>
          <th>Client</th>
          <th>Statut</th>
          <th>Zones</th>
          <th>Documents</th>
          <th style="width:120px">Actions</th>
        </tr>
      </thead>
      <tbody>
        @foreach (var item in Model)
        {
          <tr data-search="@item.Nom @item.ClientNom" data-status="@item.Statut">
            <td class="fw-500">@item.Nom</td>
            <td class="text-muted">@item.ClientNom</td>
            <td>
              @if (item.Statut == ProjetStatut.EnCours)
              { <span class="badge-status status-online">En cours</span> }
              else if (item.Statut == ProjetStatut.Termine)
              { <span class="badge-status status-offline">Terminé</span> }
              else
              { <span class="badge-status status-warning">Suspendu</span> }
            </td>
            <td>@item.ZoneCount zone(s)</td>
            <td>
              <button class="sg-upload-btn" onclick="openDocPopup(@item.Id, null, '@Html.Raw(Html.Encode(item.Nom))', sgUrls)">
                <i class="bi bi-folder me-1"></i>Voir
              </button>
            </td>
            <td>
              <div class="d-flex gap-1">
                <a asp-controller="Zones" asp-action="Index" asp-route-projetId="@item.Id"
                   class="btn sg-btn sg-btn-outline btn-sm" title="Voir les zones">
                  <i class="bi bi-geo-alt"></i>
                </a>
                @if (!User.IsInRole("Visiteur"))
                {
                  <a asp-action="Edit" asp-route-id="@item.Id"
                     class="btn sg-btn sg-btn-outline btn-sm">
                    <i class="bi bi-pencil"></i>
                  </a>
                  <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn sg-btn sg-btn-danger btn-sm">
                      <i class="bi bi-trash"></i>
                    </button>
                  </form>
                }
              </div>
            </td>
          </tr>
        }
      </tbody>
    </table>
  </div>
</div>

@section Scripts {
<link rel="stylesheet" href="~/css/gpon-fileui.css" />
<script src="~/js/gpon-fileui.js"></script>
<script>
const srch = document.getElementById('srch');
const filt = document.getElementById('filt');
function filter() {
  const s = srch.value.toLowerCase();
  const f = filt.value;
  document.querySelectorAll('#tbl tbody tr').forEach(r => {
    const matchS = !s || r.dataset.search?.toLowerCase().includes(s);
    const matchF = !f || r.dataset.status === f;
    r.style.display = (matchS && matchF) ? '' : 'none';
  });
}
srch.addEventListener('input', filter);
filt.addEventListener('change', filter);

// A2: URLs via Url.Action (jamais hardcodées)
const sgUrls = {
  getFiles:     '@Url.Action("GetFiles","Resources")',
  downloadBase: '@Url.Action("Download","Resources")'
};

// A3 guard confirmed: Delete cascade
document.querySelectorAll('form[DELETEGUARD]').forEach(form => {
  form.addEventListener('submit', async function(e) {
    e.preventDefault();
    const fd = new FormData(this);
    const res = await fetch(this.action, { method: 'POST', body: fd,
      headers: { 'X-Requested-With': 'XMLHttpRequest' } });
    const json = await res.json().catch(() => null);
    if (json?.needsConfirmation) {
      if (!confirm(`Ce projet contient ${json.count} fichier(s). Supprimer quand même ?`)) return;
      fd.append('confirmed', 'true');
      await fetch(this.action, { method: 'POST', body: fd });
    }
    window.location.href = '@Url.Action("Index")';
  });
});
</script>
}
