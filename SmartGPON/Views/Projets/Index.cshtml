@model List<ProjetDisplayVM>
@{ ViewData["Title"] = "Projets"; }
<div class="page-header d-flex justify-content-between align-items-center">
  <h1 class="page-title"><i class="bi bi-folder2-open me-2"></i>Projets</h1>
  @if (!User.IsInRole("Visiteur")) {
    <a asp-action="Create" class="btn btn-primary btn-sm"><i class="bi bi-plus-lg me-1"></i>Nouveau projet</a>
  }
</div>
@if (!Model.Any()) {
  <div class="alert alert-info">Aucun projet accessible.</div>
} else {
  <div class="card shadow-sm">
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead class="table-light"><tr>
          <th>Nom</th><th>Client</th><th>Statut</th><th class="text-end">Actions</th>
        </tr></thead>
        <tbody>
          @foreach (var p in Model) {
          var badge = p.Statut == ProjetStatut.EnCours ? "success" : (p.Statut == ProjetStatut.Suspendu ? "warning" : "secondary");
          <tr>
            <td class="fw-semibold">@p.Nom</td>
            <td>@p.ClientNom</td>
            <td><span class="badge bg-@badge">@(p.Statut == ProjetStatut.EnCours ? "En cours" : (p.Statut == ProjetStatut.Suspendu ? "Suspendu" : "Terminé"))</span></td>
            <td class="text-end">
              <a asp-action="Details" asp-route-id="@p.Id" class="btn btn-sm btn-outline-info me-1"><i class="bi bi-eye"></i></a>
              @if (!User.IsInRole("Visiteur")) {
                <a asp-action="Edit" asp-route-id="@p.Id" class="btn btn-sm btn-outline-secondary me-1"><i class="bi bi-pencil"></i></a>
                <form asp-action="Delete" asp-route-id="@p.Id" method="post" class="d-inline">
                  @Html.AntiForgeryToken()
                  <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                </form>
              }
            </td>
          </tr>
          }
        </tbody>
      </table>
    </div>
  </div>
}
