@model SmartGPON.Web.ViewModels.LoginViewModel
@{ Layout = null; }
<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="utf-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>SmartGPON - Connexion</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"/>
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet"/>
<link href="/css/site.css" rel="stylesheet"/>
</head>
<body>
<div class="auth-shell">
  <div class="auth-wrap">
    <div class="auth-card">
      <div class="auth-header">
        <div class="auth-logo auth-logo-primary"><i class="bi bi-diagram-3"></i></div>
        <div class="auth-title">Smart<span>GPON</span></div>
        <div class="auth-subtitle">Supervision reseau GPON/FTTH</div>
      </div>

      @{ var errors = ViewData.ModelState.Values.SelectMany(v => v.Errors).Select(e => e.ErrorMessage).ToList(); }
      @if (errors.Any()) {
        <div class="auth-error"><i class="bi bi-exclamation-circle-fill"></i><span>@errors.First()</span></div>
      }

      @{
        var returnUrlEncoded = ViewBag.ReturnUrl != null ? "?returnUrl=" + Uri.EscapeDataString((string)ViewBag.ReturnUrl) : "";
      }
      <form method="post" action="/Account/Login@(returnUrlEncoded)">
        @Html.AntiForgeryToken()
        <input type="hidden" name="RememberMe" value="false"/>

        <div class="auth-group">
          <label for="Email" class="auth-label">Adresse email</label>
          <input
            type="text"
            id="Email"
            name="Email"
            class="auth-input"
            value="@(Model?.Email ?? "")"
            placeholder="admin@smartgpon.local"
            autofocus
            autocomplete="username"/>
        </div>

        <div class="auth-group auth-group-last">
          <label for="Password" class="auth-label">Mot de passe</label>
          <input
            type="password"
            id="Password"
            name="Password"
            class="auth-input"
            placeholder="********"
            autocomplete="current-password"/>
        </div>

        <div class="form-check auth-remember">
          <input type="checkbox" id="RememberMeChk" name="RememberMe" value="true" class="form-check-input"/>
          <label class="form-check-label" for="RememberMeChk">Se souvenir de moi</label>
        </div>

        <button type="submit" class="auth-submit">
          <i class="bi bi-box-arrow-in-right"></i> Connexion
        </button>
      </form>

      <p class="auth-footer">SmartGPON v3 &copy; @DateTime.Now.Year</p>
    </div>
  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
