@model SmartGPON.Web.ViewModels.LoginViewModel
@{ Layout = null; }
<!DOCTYPE html><html lang="fr"><head>
<meta charset="utf-8"/><meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>SmartGPON — Connexion</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"/>
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;600&family=IBM+Plex+Sans:wght@400;500;600;700&display=swap" rel="stylesheet"/>
<style>
:root{--navy-950:#060d1f;--navy-900:#0b1628;--navy-700:#162847;--accent-cyan:#00c8e0;--accent-cyan-dim:#0097a7;--accent-violet:#7c4dff;--text-primary:#e8edf5;--text-muted:#4a5d78;--border-mid:rgba(255,255,255,.12)}
*{box-sizing:border-box}body{margin:0;background:var(--navy-950);color:var(--text-primary);font-family:'IBM Plex Sans',sans-serif;min-height:100vh;display:flex;align-items:center;justify-content:center}
.login-wrap{width:100%;max-width:420px;padding:1rem}
.login-card{background:var(--navy-900);border:1px solid var(--border-mid);border-radius:16px;padding:2.5rem}
.login-brand{text-align:center;margin-bottom:2rem}
.brand-icon{width:52px;height:52px;background:linear-gradient(135deg,var(--accent-cyan-dim),var(--accent-violet));border-radius:13px;display:flex;align-items:center;justify-content:center;font-size:24px;color:#fff;margin:0 auto .85rem}
.brand-title{font-family:'IBM Plex Mono',monospace;font-size:1.4rem;font-weight:600}
.brand-title span{color:var(--accent-cyan)}
.brand-sub{font-size:11.5px;color:var(--text-muted);margin-top:5px;font-family:'IBM Plex Mono',monospace;letter-spacing:.05em}
label{font-size:11px;color:var(--text-muted);font-family:'IBM Plex Mono',monospace;text-transform:uppercase;letter-spacing:.08em;display:block;margin-bottom:5px}
.sg-input{background:var(--navy-700);border:1px solid var(--border-mid);border-radius:8px;color:#e8edf5;padding:9px 13px;font-size:13px;width:100%;transition:border-color .2s;outline:none;font-family:'IBM Plex Sans',sans-serif}
.sg-input:focus{border-color:var(--accent-cyan);box-shadow:0 0 0 3px rgba(0,200,224,.1)}
.btn-login{width:100%;background:linear-gradient(135deg,var(--accent-cyan-dim),var(--accent-cyan));color:#060d1f;border:none;border-radius:8px;padding:11px;font-weight:700;font-size:13.5px;cursor:pointer;transition:all .2s;display:flex;align-items:center;justify-content:center;gap:8px;font-family:'IBM Plex Sans',sans-serif}
.btn-login:hover{transform:translateY(-1px);box-shadow:0 6px 20px rgba(0,200,224,.35)}
.error-box{background:rgba(255,61,87,.1);border:1px solid rgba(255,61,87,.3);border-radius:8px;padding:10px 14px;margin-bottom:16px;font-size:12.5px;color:#ff3d57;display:flex;align-items:center;gap:8px}
.form-check-label{font-size:12px;color:var(--text-muted);cursor:pointer;text-transform:uppercase;letter-spacing:.08em;font-family:'IBM Plex Mono',monospace}
.form-check-input:checked{background-color:var(--accent-cyan);border-color:var(--accent-cyan)}
.footer-txt{text-align:center;margin-top:1.2rem;font-size:11px;color:var(--text-muted);font-family:'IBM Plex Mono',monospace}
</style></head>
<body>
<div class="login-wrap"><div class="login-card">
  <div class="login-brand">
    <div class="brand-icon"><i class="bi bi-diagram-3"></i></div>
    <div class="brand-title">Smart<span>GPON</span></div>
    <div class="brand-sub">Supervision réseau GPON/FTTH</div>
  </div>

  @{ var errors = ViewData.ModelState.Values.SelectMany(v => v.Errors).Select(e => e.ErrorMessage).ToList(); }
  @if (errors.Any()) {
    <div class="error-box"><i class="bi bi-exclamation-circle-fill"></i><span>@errors.First()</span></div>
  }

  @{
    var returnUrlEncoded = ViewBag.ReturnUrl != null ? "?returnUrl=" + Uri.EscapeDataString((string)ViewBag.ReturnUrl) : "";
  }
  <form method="post" action="/Account/Login@(returnUrlEncoded)">
    @Html.AntiForgeryToken()
    <input type="hidden" name="RememberMe" value="false"/>

    <div class="mb-3">
      <label for="Email">Adresse email</label>
      <input type="text" id="Email" name="Email" class="sg-input"
             value="@(Model?.Email ?? "")" placeholder="admin@smartgpon.local" autofocus autocomplete="username"/>
    </div>
    <div class="mb-3">
      <label for="Password">Mot de passe</label>
      <input type="password" id="Password" name="Password" class="sg-input"
             placeholder="••••••••" autocomplete="current-password"/>
    </div>
    <div class="form-check mb-4">
      <input type="checkbox" id="RememberMeChk" name="RememberMe" value="true" class="form-check-input"/>
      <label class="form-check-label" for="RememberMeChk">Se souvenir de moi</label>
    </div>
    <button type="submit" class="btn-login">
      <i class="bi bi-box-arrow-in-right"></i> Connexion
    </button>
  </form>
  <p class="footer-txt">SmartGPON v3 &copy; @DateTime.Now.Year</p>
</div></div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body></html>
