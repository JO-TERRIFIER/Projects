@* Views/Account/AccessDenied.cshtml *@
@{ ViewData["Title"] = "Accès refusé"; Layout = null; }
<!DOCTYPE html><html lang="fr"><head><meta charset="utf-8"/><title>403 — SmartGPON</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet"/>
<style>
  :root{--navy-950:#060d1f;--accent-red:#ff3d57;--accent-cyan:#00c8e0;--text-primary:#e8edf5;--text-muted:#4a5d78}
  body{background:var(--navy-950);color:var(--text-primary);display:flex;align-items:center;justify-content:center;min-height:100vh;margin:0;font-family:'Segoe UI',sans-serif}
  .card{background:#0b1628;border:1px solid rgba(255,255,255,.07);border-radius:14px;padding:3rem;text-align:center;max-width:420px}
  .icon{font-size:3rem;color:var(--accent-red);margin-bottom:1rem}
  h1{font-size:1.4rem;font-weight:700;margin-bottom:.5rem}
  p{color:var(--text-muted);font-size:.9rem;margin-bottom:1.5rem}
  a{background:linear-gradient(135deg,#0097a7,var(--accent-cyan));color:#000;font-weight:600;border-radius:8px;padding:8px 20px;text-decoration:none;font-size:.9rem}
</style></head><body>
<div class="card">
  <div class="icon"><i class="bi bi-shield-lock"></i></div>
  <h1>Accès refusé</h1>
  <p>Vous n'avez pas les permissions nécessaires pour accéder à cette ressource.</p>
  <a href="/">Retour à l'accueil</a>
</div></body></html>
