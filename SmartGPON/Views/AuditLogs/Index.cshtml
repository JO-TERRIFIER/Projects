@model List<SmartGPON.Web.ViewModels.AuditLogDisplayVM>
@{ ViewData["Title"] = "Journal d'audit"; }

<div class="page-header">
  <div class="d-flex align-items-center justify-content-between mb-4">
    <div>
      <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-1">
          <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Accueil</a></li>
          <li class="breadcrumb-item active">Journal d'audit</li>
        </ol>
      </nav>
      <h1 class="h4 mb-0 fw-500">
        <i class="bi bi-journal-text me-2"></i>Journal d'audit
        <span class="text-muted small ms-2" style="font-size:13px;font-weight:400">
          — @Model.Count entrée(s) affichée(s) sur @(ViewBag.TotalCount ?? 0) au total
        </span>
      </h1>
    </div>
  </div>
</div>

<div class="page-body">

  <div class="sg-card mb-3">
    <form method="get" asp-action="Index" class="row g-2 align-items-end">
      <div class="col-md-2">
        <label class="form-label small mb-1">Type d'action</label>
        <input type="text" name="action" class="form-control form-control-sm"
               placeholder="ex: Create, Edit…" value="@ViewBag.FilterAction">
      </div>
      <div class="col-md-2">
        <label class="form-label small mb-1">Entité</label>
        <input type="text" name="entity" class="form-control form-control-sm"
               placeholder="ex: OLT, FDT…" value="@ViewBag.FilterEntity">
      </div>
      <div class="col-md-2">
        <label class="form-label small mb-1">Technicien</label>
        <input type="text" name="tech" class="form-control form-control-sm"
               placeholder="Nom ou prénom" value="@ViewBag.FilterTech">
      </div>
      <div class="col-md-2">
        <label class="form-label small mb-1">Du</label>
        <input type="date" name="from" class="form-control form-control-sm" value="@ViewBag.FilterFrom">
      </div>
      <div class="col-md-2">
        <label class="form-label small mb-1">Au</label>
        <input type="date" name="to" class="form-control form-control-sm" value="@ViewBag.FilterTo">
      </div>
      <div class="col-md-2 d-flex gap-2">
        <button type="submit" class="btn sg-btn sg-btn-primary btn-sm w-100">
          <i class="bi bi-funnel me-1"></i>Filtrer
        </button>
        <a asp-action="Index" class="btn sg-btn sg-btn-outline btn-sm" title="Réinitialiser">
          <i class="bi bi-x-circle"></i>
        </a>
      </div>
    </form>
  </div>

  <div class="sg-card">
    @if (Model.Any())
    {
      <table class="sg-table">
        <thead>
          <tr>
            <th style="width:155px">Date</th>
            <th>Technicien</th>
            <th style="width:120px">Action</th>
            <th style="width:110px">Entité</th>
            <th>Description</th>
          </tr>
        </thead>
        <tbody>
          @foreach (var item in Model)
          {
            <tr>
              <td class="text-muted" style="font-size:12px;white-space:nowrap">
                <i class="bi bi-clock me-1"></i>@item.OccurredAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
              </td>
              <td style="font-size:13px">
                @if (item.NomTech != null)
                {
                  <span><i class="bi bi-person-fill me-1 text-muted"></i>@item.PrenomTech @item.NomTech</span>
                }
                else
                {
                  <span class="text-muted small">@(item.UserId ?? "—")</span>
                }
              </td>
              <td>
                @{
                  var badgeCls = item.ActionType?.Contains("Delete", StringComparison.OrdinalIgnoreCase) == true
                    ? "status-offline"
                    : item.ActionType?.Contains("Create", StringComparison.OrdinalIgnoreCase) == true
                      ? "status-online"
                      : "status-warning";
                }
                <span class="badge-status @badgeCls">@(item.ActionType ?? "—")</span>
              </td>
              <td class="text-muted small">@(item.EntityType ?? "—")</td>
              <td class="text-muted small">@(item.Description ?? "—")</td>
            </tr>
          }
        </tbody>
      </table>
    }
    else
    {
      <div class="text-center py-5">
        <i class="bi bi-journal-x" style="font-size:48px;opacity:0.25"></i>
        <p class="mt-3 mb-1 text-muted">Aucun événement d'audit trouvé.</p>
        <p class="text-muted small mb-0">Essayez de modifier les filtres ou effectuez des actions dans l'application.</p>
      </div>
    }
  </div>
</div>
