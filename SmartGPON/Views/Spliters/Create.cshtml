@model SmartGPON.Core.Entities.Splitter
@{ ViewData["Title"] = (Model.Id==0?"Nouveau":"Modifier")+" splitter"; }
<div class="page-header"><div><h1 class="page-title">@ViewData["Title"]</h1></div><a asp-action="Index" class="btn-ghost-sg"><i class="bi bi-arrow-left"></i> Retour</a></div>
<div class="page-body"><div style="max-width:500px">
  <form asp-action="@(Model.Id==0?"Create":"Edit")" method="post">
    @Html.AntiForgeryToken()
    @if(Model.Id!=0){<input type="hidden" asp-for="Id"/>}
    <div class="form-section">
      <div class="form-section-header"><div class="sec-icon" style="background:rgba(124,77,255,.12)"><i class="bi bi-share" style="color:#a78bff"></i></div><span style="font-size:13px;font-weight:600">Splitter optique</span></div>
      <div class="form-section-body"><div class="row g-3">
        <div class="col-12"><label class="sg-label">Nom *</label><input asp-for="Nom" class="sg-input form-control" required/></div>
        <div class="col-12"><label class="sg-label">FAT parent *</label>
          <select asp-for="FatId" class="sg-input form-select" required>
            <option value="">-- Sélectionner FAT --</option>
            @foreach(var f in ViewBag.Fats as List<SmartGPON.Core.Entities.Fat>??new()){<option value="@f.Id">@f.Nom</option>}
          </select></div>
        <div class="col-md-6"><label class="sg-label">Ratio</label>
          <select asp-for="Ratio" class="sg-input form-select">
            <option value="1:2">1:2</option><option value="1:4">1:4</option><option value="1:8" selected>1:8</option>
            <option value="1:16">1:16</option><option value="1:32">1:32</option><option value="1:64">1:64</option>
          </select></div>
        <div class="col-md-6"><label class="sg-label">Nb sorties</label><input asp-for="NombreSorties" class="sg-input form-control" type="number" min="2" max="64"/></div>
        <div class="col-md-6"><label class="sg-label">Statut</label>
          <select asp-for="Statut" asp-items="Html.GetEnumSelectList<SmartGPON.Core.Enums.StatutEquipement>()" class="sg-input form-select"></select></div>
      </div></div></div>
    <div class="d-flex gap-2"><button type="submit" class="btn-primary-sg"><i class="bi bi-check-lg"></i> Enregistrer</button><a asp-action="Index" class="btn-ghost-sg">Annuler</a></div>
  </form>
</div></div>
