@model IEnumerable<SmartGPON.Core.Entities.Splitter>
@{ ViewData["Title"] = "Splitters"; }
<div class="page-header"><div><h1 class="page-title">Splitters optiques</h1><div class="page-subtitle">Diviseurs de signal GPON</div></div><a asp-action="Create" class="btn-primary-sg"><i class="bi bi-plus-lg"></i> Nouveau splitter</a></div>
<div class="page-body"><div class="sg-card p-0" style="overflow:hidden"><div style="overflow-x:auto"><table class="sg-table">
  <thead><tr><th style="padding-left:20px">Nom</th><th>FAT parent</th><th>Ratio</th><th>Sorties</th><th>ONTs</th><th>Statut</th><th style="padding-right:20px;text-align:right">Actions</th></tr></thead>
  <tbody>
  @foreach(var s in Model){
    var onts = s.Onts?.Count ?? 0;
    var pct  = s.NombreSorties > 0 ? Math.Min(100, onts * 100 / s.NombreSorties) : 0;
    var pill = s.Statut==SmartGPON.Core.Enums.StatutEquipement.Actif?"pill-green":s.Statut==SmartGPON.Core.Enums.StatutEquipement.EnPanne?"pill-red":"pill-amber";
    <tr><td style="padding-left:20px;font-weight:500;color:var(--text-primary)" class="mono">@s.Nom</td>
    <td style="font-size:12px;color:var(--text-muted)">@s.Fat?.Nom</td>
    <td><span class="pill pill-violet" style="font-size:10px">@s.Ratio</span></td>
    <td class="mono" style="color:var(--accent-cyan)">@s.NombreSorties</td>
    <td><div class="d-flex align-items-center gap-2"><span class="mono" style="font-size:12px">@onts/@s.NombreSorties</span>
      <div class="cap-bar"><div class="cap-fill" style="width:@pct%;background:@(pct>=90?"var(--accent-red)":pct>=70?"var(--accent-amber)":"var(--accent-green)")"></div></div>
    </div></td>
    <td><span class="pill @pill">@s.Statut</span></td>
    <td style="padding-right:20px;text-align:right"><div class="d-flex justify-content-end gap-1">
      <a asp-action="Edit" asp-route-id="@s.Id" class="icon-btn edit"><i class="bi bi-pencil"></i></a>
      <form asp-action="Delete" asp-route-id="@s.Id" method="post" class="d-inline" onsubmit="return confirm('Supprimer ?')">@Html.AntiForgeryToken()<button type="submit" class="icon-btn danger"><i class="bi bi-trash3"></i></button></form>
    </div></td></tr>
  }
  </tbody>
</table></div></div></div>
